# SHA256 for zlib-1.3.1.tar.gz from
# https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz
# (no prebuilt Windows binary release exists; we build libz.a from source
# using win32/Makefile.gcc with the MinGW gcc bootstrapped by Ensure-Gcc).
ZLIB_WIN_X64_SHA256=9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23
CLINGO_VERSION=5.8.0
# clingo prebuilt DLL extracted from the conda-forge package. potassco/clingo's
# GitHub releases ship only source archives on Windows; the PyPI wheel
# statically links clingo into _clingo.<pytag>.pyd and does NOT ship a
# standalone clingo.dll. Conda-forge's clingo package, on the other hand,
# bundles Library/bin/clingo.dll alongside the CLI tools (clingo.exe,
# clasp.exe, gringo.exe). The build hash encodes the Python ABI of the
# bundled _clingo.cpython-312.pyd which we ignore — the native
# clingo.dll is ABI-stable across the variants. See ensure-clingo.ps1.
CLINGO_WIN_X64_CONDA_URL=https://anaconda.org/conda-forge/clingo/5.8.0/download/win-64/clingo-5.8.0-py312he3f8637_1.conda
CLINGO_WIN_X64_CONDA_SHA256=a9e5eb699dd8de3dcc555c28f47a46ca0b3005f784f76aadf70f47267e5afee9
