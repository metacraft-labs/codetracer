# Shared version pins for Windows DIY toolchain bootstrap.
RUSTUP_VERSION=1.28.2
RUST_TOOLCHAIN_VERSION=1.92.0
JUST_VERSION=1.46.0
CARGO_NEXTEST_VERSION=0.9.132
NODE_VERSION=24.13.0
