{
  "base": "vs",
  "inherit": true,
  "rules": [
    {
      "foreground": "464646",
      "token": ""
    },
    {
      "foreground": "eb4f64",
      "token": "comment"
    },
    {
      "foreground": "eb4f64",
      "fontStyle": "underline",
      "token": "comment.doc"
    },
    {
      "foreground": "464646",
      "token": "variable"
    },
    {
      "foreground": "464646",
      "token": "variable.name"
    },
    {
      "foreground": "001080",
      "token": "variable.parameter"
    },
    {
      "foreground": "464646",
      "token": "variable.member"
    },
    {
      "foreground": "795E26",
      "token": "variable.member.function"
    },
    {
      "foreground": "0550AE",
      "fontStyle": "bold",
      "token": "variable.language"
    },
    {
      "foreground": "56a3e8",
      "token": "keyword"
    },
    {
      "foreground": "56a3e8",
      "token": "keyword.operator"
    },
    {
      "foreground": "56a3e8",
      "fontStyle": "bold",
      "token": "keyword.type"
    },
    {
      "foreground": "2dc079",
      "token": "type"
    },
    {
      "foreground": "2dc079",
      "token": "type.identifier"
    },
    {
      "foreground": "0b6ae6",
      "token": "string"
    },
    {
      "foreground": "599f89",
      "token": "number"
    },
    {
      "foreground": "599f89",
      "token": "number.hex"
    },
    {
      "foreground": "599f89",
      "token": "number.octal"
    },
    {
      "foreground": "599f89",
      "token": "number.binary"
    },
    {
      "foreground": "599f89",
      "token": "number.float"
    },
    {
      "foreground": "464646",
      "token": "delimiter"
    },
    {
      "foreground": "464646",
      "token": "delimiter.backtick"
    },
    {
      "foreground": "464646",
      "token": "operator"
    },
    {
      "foreground": "CF222E",
      "fontStyle": "bold",
      "token": "modifier.export"
    },
    {
      "foreground": "267f99",
      "fontStyle": "bold",
      "token": "entity.name.type"
    },
    {
      "foreground": "795E26",
      "fontStyle": "bold",
      "token": "entity.name.function"
    },
    {
      "foreground": "795E26",
      "token": "identifier.function"
    },
    {
      "foreground": "795E26",
      "token": "support.function"
    },
    {
      "foreground": "0070C1",
      "token": "constant"
    },
    {
      "foreground": "AF00DB",
      "token": "namespace"
    },
    {
      "foreground": "CF222E",
      "fontStyle": "bold",
      "token": "namespace.std"
    },
    {
      "foreground": "953800",
      "fontStyle": "bold",
      "token": "namespace.system"
    },
    {
      "foreground": "0550AE",
      "token": "namespace.library"
    },
    {
      "foreground": "57606A",
      "token": "namespace.except"
    },
    {
      "foreground": "E50000",
      "token": "metatag"
    },
    {
      "foreground": "0070C1",
      "token": "attribute.name"
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "macro": "#AF3DB4",
    "macro.declaration": "#AF3DB4",
    "function": "#795E26",
    "function.declaration": "#795E26",
    "method": "#795E26",
    "type": "#267F99",
    "type.declaration": "#267F99",
    "class": "#267F99",
    "enum": "#267F99",
    "interface": "#267F99",
    "struct": "#267F99",
    "typeParameter": "#0070C1",
    "parameter": "#1F377F",
    "variable": "#001080",
    "variable.readonly": "#0070C1",
    "property": "#001080",
    "enumMember": "#0070C1",
    "namespace": "#267F99",
    "decorator": "#AF3DB4",
    "label": "#001080",
    "operator": "#000000"
  },
  "colors": {
    "editor.foreground": "#f4f4f4",
    "editor.background": "#f4f4f4",
    "editor.selectionBackground": "#4f5b66",
    "editor.lineHighlightBackground": "#65737e55",
    "editorCursor.foreground": "#c0c5ce",
    "editorWhitespace.foreground": "#65737e",
    "editorIndentGuide.background": "#65737F",
    "editorIndentGuide.activeBackground": "#FBC95A",
    "editorSuggestWidget.foreground": "#464646",
    "editorSuggestWidget.background": "#F5F5F5"
  }
}
