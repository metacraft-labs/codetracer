.dropdown-list-tag
  display: flex
  align-items: center
  padding: 0.25em 0 0.25em 1em

  .ct-checkmark-field
    font-weight: 500

.dropdown-list-kind
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 0.25em 1em
  align-items: center
  padding: 0.25em 1em 0.25em 1.25em

.paging-menu
  display: flex

  .paging-page
    background-color: blue
    color: white
    cursor: pointer
    margin-left: 2px
    margin-right: 2px

  .paging-active-page
    background-color: yellow

.paging-content
  display: flex
  flex-direction: column

  .paging-child
    display: flex

    .paging-view
      flex-basis: 80%

    .paging-expand
      color: green
      flex-basis: 20%

    .paging-collapse
      color: red
      flex-basis: 20%
