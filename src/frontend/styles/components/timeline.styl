.timeline-component
  display: flex
  flex-direction: column
  height: 100%
  width: 100%
  min-height: 0
  box-sizing: border-box
  overflow: hidden
  color: colors-ui-text-primary-body
  font-family: "FiraCode"
  font-size: 13px
  line-height: 20px

  .timeline-position
    display: flex
    align-items: center
    gap: 12px
    padding: 6px 10px
    flex: 0 0 auto
    color: colors-ui-text-primary-body
    border-bottom: 1px solid colors-ui-surface-input-default
    background: colors-ui-surface-primary-tertiary

  .position-ticks
    color: colors-ui-text-primary-body

  .timeline-zoom-controls
    display: flex
    align-items: center
    gap: 4px
    padding: 8px 10px
    flex: 0 0 auto

    button
      width: 24px
      height: 24px
      border: 0
      border-radius: 4px
      background: colors-ui-surface-primary-tertiary
      color: colors-ui-text-primary-body
      cursor: pointer
      font: inherit

  .zoom-level
    min-width: 42px
    text-align: center
    color: colors-ui-text-primary-body

  .timeline-track
    position: relative
    height: 42px
    margin: 0 10px
    border-top: 1px solid colors-ui-surface-input-default
    border-bottom: 1px solid colors-ui-surface-input-default
    background:
      linear-gradient(90deg, colors-ui-border-secondary 1px, transparent 1px),
      linear-gradient(to bottom, transparent 19px, colors-ui-surface-primary-secondary-hover 20px, transparent 21px)
    background-size: 40px 100%, 100% 100%
    flex: 0 0 auto
    cursor: pointer

  .timeline-playhead
    position: absolute
    top: 0
    bottom: 0
    width: 2px
    background: #d7ba7d
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.35)

  .timeline-hover-tooltip
    width: fit-content
    margin: 8px
    padding: 2px 6px
    border-radius: 4px
    background: colors-ui-surface-primary-tertiary
    color: colors-ui-text-primary-body
    font-size: 12px
