// Session tab bar (M10) — rendered inside the caption/menu bar area,
// next to the omnibox / command palette.  Visually sits in the title bar
// like browser tabs.

.session-tab-bar
  display flex
  align-items center
  // Position the tab bar inside the menu/caption bar area.
  // It is a sibling element in the DOM but overlaps the #menu visually.
  position fixed
  top 0
  // Place tabs after the centered omnibox and before the window controls.
  right 120px
  left calc(2.25em + 34em + min(20em, 20vw) + 1.5em)
  height 38px
  padding 0 4px
  z-index 21  // Above #menu (z-index 20) so tabs are clickable
  -webkit-app-region no-drag
  overflow hidden

  // When there is only a single session, keep the tab bar in the DOM but
  // hide the individual tab labels (the lone tab just shows the trace path
  // and wastes horizontal space).  The "+" button remains visible so the
  // user can open additional sessions at any time.
  &.single-session
    .session-tab
      display none

  &.has-overflow
    .session-tab-overflow
      display flex

  &.overflow-open
    overflow visible

    .session-tab-overflow-menu
      display flex

.session-tab
  display flex
  align-items center
  flex 0 1 160px
  min-width 36px
  padding 0 10px
  height 26px
  cursor pointer
  color #b0b0b0
  opacity 0.7
  font-size 12px
  border-radius 4px
  margin-right 2px
  white-space nowrap
  user-select none
  transition background-color 150ms ease, color 150ms ease, opacity 150ms ease
  -webkit-app-region no-drag
  &:hover
    color PRIMARY_TEXT_COLOR
    opacity 1.0
    background-color ACTIVE_ROW
  &.active
    background-color #3c3c3c
    color #ffffff
    opacity 1.0

.session-tab-label
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  min-width 0
  flex 1 1 auto
  max-width 160px

.session-tab-close
  margin-left 8px
  font-size 14px
  cursor pointer
  opacity 0.4
  transition opacity 150ms ease
  &:hover
    opacity 1

// Session GL containers — each session keeps its own GoldenLayout instance
// alive.  Switching sessions toggles visibility instead of destroy/recreate.
.session-container
  width 100%
  height 100%

.session-container.hidden
  display none

.session-tab-add
  display flex
  align-items center
  justify-content center
  flex 0 0 26px
  width 26px
  height 26px
  cursor pointer
  color #b0b0b0
  font-size 16px
  user-select none
  border-radius 4px
  -webkit-app-region no-drag
  transition color 150ms ease, background-color 150ms ease
  &:hover
    color PRIMARY_TEXT_COLOR
    background-color ACTIVE_ROW

.session-tab-overflow
  display none
  align-items center
  justify-content center
  flex 0 0 26px
  width 26px
  height 26px
  margin-right 2px
  cursor pointer
  color #b0b0b0
  font-size 12px
  user-select none
  border-radius 4px
  -webkit-app-region no-drag
  transition color 150ms ease, background-color 150ms ease
  &:hover
    color PRIMARY_TEXT_COLOR
    background-color ACTIVE_ROW

.session-tab-overflow-menu
  display none
  position absolute
  right 4px
  top 34px
  min-width 220px
  max-width 360px
  max-height 70vh
  overflow auto
  flex-direction column
  padding 4px
  border-radius 6px
  background-color colors-ui-surface-primary-default
  border 1px solid colors-ui-border-primary
  box-shadow 0 12px 30px rgba(0, 0, 0, 0.35)
  z-index 120
  -webkit-app-region no-drag

.session-tab-overflow-item
  min-height 28px
  padding 0 10px
  display flex
  align-items center
  color #b0b0b0
  font-size 12px
  cursor pointer
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  border-radius 4px
  &.active
    background-color #3c3c3c
    color #ffffff
  &:hover
    color PRIMARY_TEXT_COLOR
    background-color ACTIVE_ROW
