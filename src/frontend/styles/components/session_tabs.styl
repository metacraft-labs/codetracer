// Session tab bar (M10) — rendered inside the caption/menu bar area,
// next to the omnibox / command palette.  Visually sits in the title bar
// like browser tabs.

.session-tab-bar
  display flex
  align-items center
  // Flex child of the caption bar: menu/debug controls/omnibox/tabs share
  // one row, so the new-tab button cannot drift over the omnibox.
  order 4
  position relative
  flex 1 1 auto
  min-width 56px
  max-width 100%
  height 100%
  padding 0 1px
  z-index 21  // Above #menu (z-index 20) so tabs are clickable
  -webkit-app-region no-drag
  overflow hidden
  box-sizing border-box

  // When there is only a single session, keep the tab bar in the DOM but
  // hide the individual tab labels (the lone tab just shows the trace path
  // and wastes horizontal space).  The "+" button remains visible so the
  // user can open additional sessions at any time.
  &.single-session
    .session-tab
      display none

  &.has-overflow
    .session-tab-overflow
      display flex

  &.overflow-open
    overflow visible

    .session-tab-overflow-menu
      display flex

.session-tab
  display flex
  align-items center
  flex 0 1 160px
  min-width 96px
  max-width 160px
  padding 0 10px
  height 26px
  cursor pointer
  color #b0b0b0
  opacity 0.7
  font-size 12px
  border-radius 4px
  margin-right 2px
  white-space nowrap
  user-select none
  transition background-color 150ms ease, color 150ms ease, opacity 150ms ease
  -webkit-app-region no-drag
  &:hover
    color colors-ui-text-primary-body
    opacity 1.0
    background-color colors-ui-surface-primary-secondary-hover
  &.active
    background-color #3c3c3c
    color #ffffff
    opacity 1.0

.session-tab-label
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  min-width 0
  flex 1 1 auto

.session-tab-close
  margin-left 8px
  font-size 14px
  cursor pointer
  opacity 0.4
  transition opacity 150ms ease
  &:hover
    opacity 1

// Session GL containers — each session keeps its own GoldenLayout instance
// alive.  Switching sessions toggles visibility instead of destroy/recreate.
.session-container
  width 100%
  height 100%

.session-container.hidden
  display none

.session-tab-add
  display flex
  align-items center
  justify-content center
  flex 0 0 auto
  width 1.75em
  height 1.75em
  cursor pointer
  user-select none
  border-radius 0.375em
  border 0.03125em solid colors-ui-border-primary
  background-color colors-ui-surface-primary-default
  color colors-ui-text-primary-body-subtle
  font-size 1em
  line-height 1
  -webkit-app-region no-drag
  transition color 150ms ease, background-color 150ms ease
  &:hover
    color colors-ui-text-primary-body
    background-color colors-ui-surface-primary-default-hover

.session-tab-overflow
  display none
  align-items center
  justify-content center
  flex 0 0 26px
  width 26px
  height 26px
  margin-right 2px
  cursor pointer
  color #b0b0b0
  font-size 18px
  line-height 1
  user-select none
  border-radius 4px
  -webkit-app-region no-drag
  transition color 150ms ease, background-color 150ms ease
  &:hover
    color colors-ui-text-primary-body
    background-color colors-ui-surface-primary-secondary-hover

.session-tab-overflow-menu
  display none
  position absolute
  right 4px
  top 34px
  min-width 220px
  max-width 360px
  max-height 70vh
  overflow auto
  flex-direction column
  padding 4px
  border-radius 6px
  background-color colors-ui-surface-primary-default
  border 1px solid colors-ui-border-primary
  box-shadow 0 12px 30px rgba(0, 0, 0, 0.35)
  z-index 120
  -webkit-app-region no-drag

.session-tab-overflow-item
  min-height 28px
  padding 0 10px
  display flex
  align-items center
  color #b0b0b0
  font-size 12px
  cursor pointer
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  border-radius 4px
  &.active
    background-color #3c3c3c
    color #ffffff
  &:hover
    color colors-ui-text-primary-body
    background-color colors-ui-surface-primary-secondary-hover
