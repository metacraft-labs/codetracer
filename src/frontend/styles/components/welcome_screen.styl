// Welcome screen widget styles
#welcomeScreen
  position: fixed
  top: 2.1em
  left: 0
  right: 0
  bottom: 2em
  z-index: 10
  display: none
  pointer-events: none
  overflow: auto

  .window-menu
    align-items: start
    height: 1.75em

#welcomeScreen .welcome-screen-root
  height: 100%
  min-height: 100%

.welcome-screen-loading-overlay
  position: absolute
  top: 0
  background-color: black
  width: 100%
  height: 100%
  opacity: 0.8
  z-index: 100
  display: flex
  align-items: center
  justify-content: center

  &-text
    padding-left: 0.625em
    color: white
    font-size: x-large
    font-style: italic

  .welcome-screen-loading-overlay-icon
    width: 2em
    height: 2em
    background-repeat: no-repeat
    background-position: center
    background-image: url("../../public/resources/welcome/loading_sign_dots_32.svg")
    animation: infinite linear
    animation-name: loading
    animation-duration: 3s

.welcome-logo
  background-image: url('../../public/resources/shared/codetracer_welcome_logo.svg')
  min-width: 3.875em
  min-height: 3.875em
  background-size: 3.875em 3.875em
  background-position: center
  margin-right: 0.75em
  background-repeat: no-repeat

.welcome-screen-wrapper
  color: WELCOME_SCREEN_TEXT_COLOR;
  background-color: WELCOME_SCREEN_BACKGROUND_COLOR;
  min-height: 100%;
  height: 100%;
  position: relative;
  width: 100%;
  z-index: 50
  display: flex;
  justify-content: center;
  align-items: center
  border-radius: 0
  pointer-events: auto

  .welcome-screen
    position: relative
    height: fit-content
    background-color: gradien
    width: 56.25em
    padding: 3em
    padding-bottom: 3.75em
    background: WELCOME_SCREEN_BACKGROUND_COLOR
    display: flex
    flex-direction: column
    border-radius: 0.75em
    align-items: center
    border: 0.0625em solid LINE_STROKE

    &.welcome-screen-loading
      cursor: wait !important

    .welcome-title
      position: relative
      font-family: "SpaceMono"
      text-align: start
      display: flex
      align-items: flex-end
      justify-content: space-between
      color: WELCOME_SCREEN_TEXT_COLOR
      width: -webkit-fill-available

      .welcome-text
        word-break: break-word
        display: flex
        align-items: center
        font-weight: BOLD_WEIGHT
        width: 19em
        font-size: 2em
        letter-spacing: -0.02em

      .welcome-version
        color: WELCOME_SCREEN_VERSION_TEXT_COLOR
        font-size: 0.75em
        font-family: "SpaceMono"
        font-weight: 400
        line-height: normal
        text-align: center

    .welcome-content
      display: flex
      flex-direction: row
      gap: 1em
      width: -webkit-fill-available

    .welcome-left-panel
      flex: 1
      display: flex
      flex-direction: column
      min-width: 0

    .welcome-right-panel
      flex: 1
      display: flex
      flex-direction: column
      min-width: 0

    // Start options - direct child of .welcome-screen
    .start-options
      position: relative
      display: flex
      width: -webkit-fill-available
      gap: 0.5em
      justify-content: space-between

      .start-option
        position: relative
        right: 0
        display: flex
        cursor: pointer
        justify-content: center
        font-family: "SpaceGrotesk"

        &.hovered
          opacity: 1

      .inactive-start-option
        opacity: 0.2
        pointer-events: none

        &.hovered
          color: inherit
          opacity: 0.2

      .start-option-icon
        width: 6.25em
        height: 6.25em
        background-image: WELCOME_SCREEN_OPTIONS_RECORD_ICON
        background-repeat: no-repeat
        background-position: center

        &.hovered
          background-image: WELCOME_SCREEN_OPTIONS_RECORD_ICON_HOVERED
          opacity: 1

      .start-option-name
        text-align: center
        font-size: 0.875em
        font-weight: BOLD_WEIGHT
        letter-spacing: -0.00875em
        line-height: 1.125em
        background-color: ACTIVE_ROW
        display: flex
        align-items: center
        color: WELCOME_SCREEN_OPTIONS_TEXT_COLOR
        justify-content: center
        white-space: nowrap
        padding: 0.375em
        padding-left: 0.875em
        padding-right: 0.875em
        border-radius: 0.375em

        &.hovered
          // color: WELCOME_SCREEN_OPTIONS_TEXT_COLOR_HOVERED
          // background-color: PRIMARY_BASE
          outline: 0.0625em solid SEARCH_STROKE
          opacity: 1

    // Recent traces styles - in welcome-right-panel
    .recent-traces
      position: relative
      width: -webkit-fill-available
      background-color: SECONDARY_BASE
      border-radius: 0.375em
      padding: 0.5em
      margin-top: 3em
      margin-bottom: 3em
      padding-right: 0
      overflow: visible

    .recent-traces-title
      text-align: start
      font-size: 1.125em
      font-weight: BOLD_WEIGHT
      line-height: 1.125em
      letter-spacing: -0.01125em
      font-family: "SpaceGrotesk"
      margin-bottom: 0.375em

    .recent-traces-list
      max-height: 10.75em
      overflow-y: auto
      overflow-x: visible
      // Allow tooltips to overflow - they use position: absolute and high z-index
      clip-path: none

      .empty-state-message
        display: flex
        flex-direction: column
        gap: 0.5em

        .empty-state-welcome
          font-size: 1em
          font-weight: 600
          font-family: "SpaceGrotesk"
          color: PRIMARY_TEXT_COLOR

        .empty-state-text
          font-size: 0.8125em
          font-family: "SpaceGrotesk"
          color: #888888
          line-height: 1.5

      .recent-trace-container
        display: flex
        align-items: center
        justify-content: space-between

      .recent-trace
        color: WELCOME_SCREEN_RECENT_TRACE_COLOR
        background-color: WELCOME_SCREEN_RECENT_PROJECT_BACKGROUND_COLOR
        height: 1.75em
        margin-top: 0.125em
        margin-bottom: 0.375em
        display: flex
        position: relative
        text-align: left
        border-radius: 0.25em
        width: -webkit-fill-available

        &:hover
          cursor: pointer
          background-color: PRIMARY_BASE

          .recent-trace-tooltip
            opacity: 1
            visibility: visible
            transition-delay: 0.5s

        .recent-trace-title
          display: flex
          align-items: center
          position: relative
          flex: 1
          min-width: 0

          .separate-bar
            border-color: WELCOME_SCREEN_SEPARATE_BAR_COLOR

          .recent-trace-title-time
            margin-left: 0.5em
            margin-right: 0.5em
            font-size: 0.75em
            font-family: "SpaceGrotesk"
            line-height: 1.125em
            color: #888888
            white-space: nowrap
            // min-width: 90px

          .recent-trace-title-content
            margin-left: 0.5em
            margin-right: 0.5em
            font-size: 0.875em
            font-weight: BOLD_WEIGHT
            font-family: "SpaceGrotesk"
            line-height: 1.125em
            letter-spacing: -0.00875em
            position: relative
            overflow: hidden
            white-space: nowrap
            text-overflow: ellipsis
            flex: 1

        .recent-trace-tooltip
          position: fixed
          background-color: #1B1B1B
          color: #f3f3f3
          padding: 0.5em 0.75em
          font-size: 0.75em
          font-family: "SpaceMono"
          border-radius: 0.25em
          white-space: pre-line
          box-shadow: 0 0.25em 0.75em rgba(0, 0, 0, 0.4)
          opacity: 0
          visibility: hidden
          transition: opacity 0.2s ease, visibility 0.2s ease
          pointer-events: none
          z-index: 1000
          max-width: 25em
          line-height: 1.4
          // Position is set via JavaScript on hover (right of the trace row).
          // Safe off-screen default so it never flashes at center.
          left: -624.9375em
          top: -624.9375em
          transform: none

    // Recent folders styles - in welcome-left-panel
    .recent-folders
      position: relative
      width: -webkit-fill-available
      background-color: SECONDARY_BASE
      border-radius: 0.375em
      padding: 0.5em
      margin-top: 3em
      margin-bottom: 3em
      padding-right: 0

    .recent-folders-title
      text-align: start
      font-size: 1.125em
      font-weight: BOLD_WEIGHT
      line-height: 1.125em
      letter-spacing: -0.01125em
      font-family: "SpaceGrotesk"
      margin-bottom: 0.375em

    .recent-folders-list
      max-height: 10.75em
      overflow-y: scroll
      overflow-x: visible

      .empty-state-message
        display: flex
        flex-direction: column
        gap: 0.5em

        .empty-state-welcome
          font-size: 1em
          font-weight: 600
          font-family: "SpaceGrotesk"
          color: PRIMARY_TEXT_COLOR

        .empty-state-text
          font-size: 0.8125em
          font-family: "SpaceGrotesk"
          color: #888888
          line-height: 1.5

      .recent-folder-container
        display: flex
        align-items: center
        justify-content: space-between

      .recent-folder
        color: WELCOME_SCREEN_RECENT_TRACE_COLOR
        background-color: WELCOME_SCREEN_RECENT_PROJECT_BACKGROUND_COLOR
        height: 1.75em
        margin-top: 0.125em
        margin-bottom: 0.375em
        display: flex
        position: relative
        text-align: left
        border-radius: 0.25em
        width: -webkit-fill-available

        &:hover
          cursor: pointer
          background-color: PRIMARY_BASE

        .recent-folder-name
          margin-left: 0.5em
          margin-right: 0.5em
          font-size: 0.875em
          font-weight: BOLD_WEIGHT
          font-family: "SpaceMono"
          line-height: 1.125em
          letter-spacing: -0.00875em
          position: relative
          overflow: hidden
          white-space: nowrap
          text-overflow: ellipsis
          display: flex
          align-items: center

  .new-record-screen
    position: relative
    display: flex
    align-items: center
    justify-content: center
    z-index: 50

    hr
      border-color: HEADER_ELEMENT_BACKGROUND_COLOR

    .new-record-screen-content
      position: relative
      width: 43.75em
      background: WELCOME_SCREEN_BACKGROUND_COLOR
      border: 0.0625em solid LINE_STROKE
      border-radius: 0.75em
      padding: 3em
      padding-bottom: 3.75em

      .welcome-logo
        min-width: 2.5em
        max-width: 2.5em
        min-height: 2.5em
        background-size: 2.5em 2.5em

    .new-record-title
      position: relative
      font-size: 2em
      font-family: "SpaceMono"
      font-weight: BOLD_WEIGHT
      text-align: start
      width: 100%
      letter-spacing: -0.02em
      line-height: 2em
      margin-bottom: 2em
      margin-top: 2em

    .new-record-form

      .new-record-form-row
        display: flex;
        align-items: center;
        flex-direction: column;
        margin-top: 0.3125em

        .form-validation-row
