// Right click context menu in the code editor
#context-menu-container
  width: fit-content
  display: none
  flex-direction: column
  // border: 0.0625em solid grey
  position: absolute
  background-color: NAVIGATION_MENU_BACKGROUND_COLOR
  border-radius: 0.375em
  padding-top: 0.25em
  padding-bottom: 0.25em
  font-family: "SpaceMono"
  font-size: 0.875em
  z-index: 1000

.context-menu-item-container
  background-color: NAVIGATION_MENU_BACKGROUND_COLOR
  line-height: 1.75em

.context-menu-item
  cursor: pointer
  color: NAVIGATION_MENU_COLOR
  display: flex
  flex-direction: row
  // border: 0.0625em solid white
  // height: 1.5em
  margin-left: 0.25em
  margin-right: 0.25em
  padding-left: 0.5em
  padding-right: 0.5em
  border-radius: 0.375em
  justify-content: space-between
  text-align: left
  align-items: center
  white-space: nowrap

  &:hover
    background-color: NAVIGATION_MENU_ACTIVE_BACKGROUND_COLOR

.context-menu-hint
  color: MENU_NODE_SHORTCUT_TEXT_COLOR
  text-align: right
  font-size: 0.625em
  padding: 0.25em
  line-height: 0.625em
  // margin-right: 0.5em
  margin-left: 0.5em
  background-color: MENU_NODE_SHORTCUT_BACKGROUND
  border-radius: 0.375em
  line-height: 0.625em

