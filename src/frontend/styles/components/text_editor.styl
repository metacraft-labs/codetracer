  color: COLOR

  .dataTables_length
    display: none

  .dataTables_info
    display: none

  .dataTables_paginate
    display: none

.context-menu
  position: fixed
  z-index: 10000
  width: fit-content
  background-color: BACKGROUND_COLOR
  border-radius: 0.3125em
  display: none

  &:focus
    outline: 0 !important
    border: 0.0625em solid DROPDOWN_TEXT_COLOR !important

  &.visible
    display: block

.context-menu-option
  height: 1.5625em
  color: DROPDOWN_TEXT_COLOR
  background-color: DROPDOWN_LIST_BACKGROUND_COLOR
  border-radius: 0.3125em
  padding-right: 0.625em
  padding-left: 0.625em
  font-size: 0.875em
  display: flex
  align-items: center

  &:hover
    background-color: DROPDOWN_LIST_FOCUSED_BACKGROUND_COLOR
    color: DROPDOWN_TEXT_FOCUSED_COLOR

.context-menu-option-text
  width: 100%

.gutter
  width: calc(100% - var(--ct-gutter-folding-lane) - var(--ct-gutter-marker-gap))
  height: 100%
  position: relative
  box-sizing: border-box
  display: block
  overflow: hidden
  cursor: pointer
  // &:hover
  // TODO relative to font size margin top/width/height
  .gutter-trace
    width: var(--ct-gutter-trace-size)
    background: TRACEPOINT_COLOR
    height: var(--ct-gutter-trace-size)
    border-radius: 50%
    top: 0
    margin-top: 0.57ch
    position: absolute
    right: var(--ct-gutter-trace-right)
    z-index: 9
    outline: 0.125em solid SECONDARY_BASE

  .gutter-disabled-trace
    width: var(--ct-gutter-trace-size) !important
    background: PRIMARY_BASE
    height: var(--ct-gutter-trace-size)
    border-radius: 50%
    top: 0
    margin-top: 0.57ch
    position: absolute
    right: var(--ct-gutter-trace-right)
    z-index: 9
    outline: 0.125em solid SECONDARY_BASE

  .gutter-breakpoint-enabled
    width: var(--ct-gutter-breakpoint-size)
    background: BREAKPOINT_COLOR
    height: var(--ct-gutter-breakpoint-size)
    border-radius: 50%
    top: 0
    margin-top: 0.63ch
    position: absolute
    right: var(--ct-gutter-breakpoint-right)
    z-index: 8

  .gutter-breakpoint-error
    width: var(--ct-gutter-breakpoint-size)
    background: red
    height: var(--ct-gutter-breakpoint-size)
    border-radius: 50%
    top: 0
    margin-top: 0.25em
    position: absolute
    right: var(--ct-gutter-breakpoint-right)

  .gutter-breakpoint-disabled
    width: var(--ct-gutter-breakpoint-size)
    background: PRIMARY_BASE
    height: var(--ct-gutter-breakpoint-size)
    border-radius: 50%
    top: 0
    margin-top: 0.63ch
    position: absolute
    right: var(--ct-gutter-breakpoint-right)
    z-index: 8

  .gutter-no-breakpoint
    width: var(--ct-gutter-breakpoint-size)
    height: var(--ct-gutter-breakpoint-size)
    background: transparent
    top: 0
    position: absolute
    margin-top: 0.63ch
    right: var(--ct-gutter-breakpoint-right)
    z-index: 8

  .gutter-no-trace
    width: var(--ct-gutter-trace-size)
    height: var(--ct-gutter-trace-size)
    background: transparent
    top: 0
    position: absolute
    margin-top: 0.57ch
    right: var(--ct-gutter-trace-right)
    z-index: 9

  &:hover > .gutter-no-breakpoint
    background: BREAKPOINT_COLOR
    border-radius: 50%
    margin-top: 0.63ch
    opacity: 0.3

  .gutter-no-highlight
    display: none


  .gutter-line
    width: calc(100% - var(--ct-gutter-pointer-lane) - var(--ct-gutter-marker-lane) - (var(--ct-gutter-line-gap) * 2))
    height: 100%
    display: block
    box-sizing: border-box
    margin-left: calc(var(--ct-gutter-pointer-lane) + var(--ct-gutter-line-gap))
    margin-right: var(--ct-gutter-line-gap)
    padding-left: 0
    padding-right: 0.15em
    text-align: right
    white-space: nowrap
    // overflow: hidden
    cursor: default
//font-weight: bold

.line-numbers
  // border-right: 0.0625em solid LINE_NUMBERS_BORDER_COLOR
  width: 100% !important
  display: block !important
  box-sizing: border-box
  margin-left: 0 !important
  font-weight: 300
  text-align: right !important
  font-family: "SpaceMono"
