.search-component
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden
  background: BACKGROUND_COLOR
  color: TEXT_CONTENT_COLOR
  font-family: "SpaceGrotesk", sans-serif
  font-size: 13px

.search-mode-selector
  flex: 0 0 auto
  display: flex
  gap: 0.375em
  padding: 0.5em
  border-bottom: 1px solid ACTIVE_MENU_BACKGROUND
  background: HEADER_PANEL_BACKGROUND_COLOR

  button
    height: 24px
    padding: 0 0.75em
    border: 1px solid transparent
    border-radius: 0.25em
    background: ACTIVE_MENU_BACKGROUND
    color: DROPDOWN_TEXT_COLOR
    font: inherit
    cursor: pointer

    &:hover,
    &.active
      background: HOVERED_BUTTON_BACKGROUND_COLOR
      color: TEXT_CONTENT_COLOR
      border-color: BORDERS_COLOR

.search-input-row
  flex: 0 0 auto
  padding: 0.5em
  border-bottom: 1px solid ACTIVE_MENU_BACKGROUND

.search-query-input
  width: 100%
  height: 30px
  box-sizing: border-box
  border: 1px solid #4f4f4f
  border-radius: 0.25em
  background: #151515
  color: TEXT_CONTENT_COLOR
  padding: 0 0.75em
  font: inherit
  outline: 0

.search-results
  flex: 1 1 auto
  min-height: 0
  overflow: auto
  background: BACKGROUND_COLOR

  &[display="none"]
    display: none

.search-result-row
  display: grid
  grid-template-columns: minmax(12em, 1fr) minmax(14em, 32em) 6em
  align-items: center
  column-gap: 1em
  min-height: 28px
  padding: 0 0.75em
  border-bottom: 1px solid EVENT_LOG_ROWS_BORDERS_COLOR
  cursor: pointer

  &:hover,
  &.selected
    background: ACTIVE_ROW

.search-result-label,
.search-result-detail
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

.search-result-detail,
.search-result-shortcut,
.search-selected-indicator
  color: VALUE_TYPE_COLOR

.search-selected-indicator
  display: block
  padding: 0.5em 0.75em
  font-family: "FiraCode", monospace
  font-size: 12px

  &.active
    color: TEXT_CONTENT_COLOR
