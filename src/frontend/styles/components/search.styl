.search-component
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden
  background: colors-ui-surface-base-panel
  color: colors-ui-text-primary-body
  font-family: "SpaceGrotesk", sans-serif
  font-size: 13px

.search-mode-selector
  flex: 0 0 auto
  display: flex
  gap: 0.375em
  padding: 0.5em
  border-bottom: 1px solid colors-ui-surface-input-default
  background: colors-ui-surface-primary-tertiary

  button
    height: 24px
    padding: 0 0.75em
    border: 1px solid transparent
    border-radius: 0.25em
    background: colors-ui-surface-input-default
    color: colors-ui-text-primary-body
    font: inherit
    cursor: pointer

    &:hover,
    &.active
      background: colors-ui-surface-primary-secondary-hover
      color: colors-ui-text-primary-body
      border-color: colors-ui-border-secondary

.search-input-row
  flex: 0 0 auto
  padding: 0.5em
  border-bottom: 1px solid colors-ui-surface-input-default

.search-query-input
  width: 100%
  height: 30px
  box-sizing: border-box
  border: 1px solid #4f4f4f
  border-radius: 0.25em
  background: #151515
  color: colors-ui-text-primary-body
  padding: 0 0.75em
  font: inherit
  outline: 0

.search-results
  flex: 1 1 auto
  min-height: 0
  overflow: auto
  background: colors-ui-surface-base-panel

  &[display="none"]
    display: none

.search-result-row
  display: grid
  grid-template-columns: minmax(12em, 1fr) minmax(14em, 32em) 6em
  align-items: center
  column-gap: 1em
  min-height: 28px
  padding: 0 0.75em
  border-bottom: 1px solid colors-ui-border-secondary
  cursor: pointer

  &:hover,
  &.selected
    background: colors-ui-surface-primary-secondary-hover

.search-result-label,
.search-result-detail
  min-width: 0
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

.search-result-detail,
.search-result-shortcut,
.search-selected-indicator
  color: colors-ui-text-primary-body

.search-selected-indicator
  display: block
  padding: 0.5em 0.75em
  font-family: "FiraCode", monospace
  font-size: 12px

  &.active
    color: colors-ui-text-primary-body
