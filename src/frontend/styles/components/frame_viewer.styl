.frame-viewer-component
  display: flex
  flex-direction: column
  height: 100%
  width: 100%
  min-height: 0
  box-sizing: border-box
  overflow: hidden
  color: colors-ui-text-primary-body
  background: colors-ui-surface-base-panel
  font-family: "FiraCode"
  font-size: 13px
  line-height: 20px

  .frame-viewer-toolbar
    display: flex
    align-items: center
    justify-content: space-between
    gap: 12px
    padding: 6px 10px
    flex: 0 0 auto
    border-bottom: 1px solid colors-ui-surface-input-default
    background: colors-ui-surface-primary-tertiary

  .frame-viewer-player-url
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    color: colors-ui-text-primary-body

  .frame-viewer-connection-status
    border-radius: 4px
    font-size: 11px
    font-weight: 600
    padding: 2px 7px
    text-transform: uppercase
    white-space: nowrap

    &.connected
      background: rgba(61, 135, 90, 0.24)
      color: #8cd9a8

    &.disconnected,
    &.absent
      background: rgba(142, 119, 56, 0.24)
      color: #d8c06f

  .frame-viewer-frame-controls
    display: inline-flex
    align-items: center
    gap: 6px
    flex: 0 0 auto

    button
      width: 24px
      height: 24px
      border: 0
      border-radius: 4px
      background: colors-ui-surface-primary-tertiary
      color: colors-ui-text-primary-body
      cursor: pointer
      font: inherit

  .frame-viewer-frame-label
    min-width: 8em
    text-align: center
    color: colors-ui-text-primary-body

  .frame-viewer-scrubber
    padding: 6px 10px
    flex: 0 0 auto
    border-bottom: 1px solid colors-ui-surface-input-default

  .frame-viewer-frame-range
    width: 100%

  .frame-viewer-body
    display: grid
    grid-template-columns: minmax(220px, 1fr) minmax(180px, 280px)
    min-height: 0
    flex: 1 1 auto

  .frame-viewer-frame-stage
    display: flex
    align-items: center
    justify-content: center
    min-width: 0
    min-height: 0
    overflow: auto
    padding: 12px
    background: #101010

  .frame-viewer-image
    display: block
    max-width: 100%
    max-height: 100%
    image-rendering: pixelated
    border: 1px solid colors-ui-border-secondary
    background: #000
    cursor: crosshair

    &[display="none"]
      display: none

  .frame-viewer-empty,
  .frame-viewer-loading,
  .frame-viewer-error
    color: colors-ui-text-primary-body
    padding: 12px

    &[display="none"]
      display: none

  .frame-viewer-error
    color: colors-ui-text-error-primary

  .frame-viewer-side-panel
    display: flex
    flex-direction: column
    min-width: 0
    min-height: 0
    border-left: 1px solid colors-ui-surface-input-default
    background: colors-ui-surface-primary-tertiary

  .frame-viewer-selected-pixel
    padding: 8px 10px
    flex: 0 0 auto
    color: colors-ui-text-primary-body
    border-bottom: 1px solid colors-ui-surface-input-default

  .frame-viewer-draw-calls
    min-height: 0
    overflow: auto
    flex: 1 1 auto

  .frame-viewer-draw-calls-header
    position: sticky
    top: 0
    z-index: 1
    padding: 6px 10px
    color: colors-ui-text-primary-body
    background: colors-ui-surface-primary-tertiary
    border-bottom: 1px solid colors-ui-surface-input-default

  .frame-viewer-draw-calls-empty
    padding: 8px 10px
    color: colors-ui-text-primary-body

  .frame-viewer-draw-call
    display: grid
    grid-template-columns: 1fr
    gap: 2px
    width: 100%
    min-height: 42px
    padding: 6px 10px
    border: 0
    border-bottom: 1px solid colors-ui-border-secondary
    background: transparent
    color: colors-ui-text-primary-body
    font: inherit
    text-align: left
    cursor: pointer

    &:hover,
    &.selected
      background: colors-ui-surface-primary-secondary-hover

  .frame-viewer-draw-call-name,
  .frame-viewer-draw-call-pipeline
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

  .frame-viewer-draw-call-pipeline
    color: colors-ui-text-primary-body
    font-size: 12px
