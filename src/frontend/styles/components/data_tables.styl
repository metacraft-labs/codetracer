.dts_label
  display: none !important

.data-table
  // font-family: Arial, Helvetica, sans-serif
  font-size: inherit !important
  font-weight: 400 !important
  font-family: "SpaceMono"
  letter-spacing: -0.00875em !important
  flex: 1 1 auto
  overflow: hidden
  min-height: 0
  color: COLOR

  .rr-ticks-line-container
    position: relative
    height: 0.3em

    .rr-ticks-line
      display: inline-block
      background: CT_SECONDARY_BLUE
      height: 0.1875em !important

  .rr-ticks-empty-remaining
    display: inline-block
    background-color: RR_TICKS_EMPTY_REMAINING_COLOR
    height: 0.1875em !important
    position: absolute
    z-index: 2

  .rr-ticks-time-container
    // font-family: sans-serif
    width: 100%
    height: 1.25em
    line-height: 2em
    position: relative

    .rr-ticks-time
      position: unset
      text-indent: -50%

  .direct-location-rr-ticks
    display: inline-block
    position: relative
    min-width: 10%
    max-width: 35%
    padding-left: 3ex
    padding-right: 3ex
    max-height: 1.5em
    transform: translateY(-0.24em)

  .event-rr-ticks-line
    height: 0.125em
    width: 100%
    display: inline-block
    position:absolute
    z-index: 0

  .paging_simple_numbers
    display: none

  .dataTables_length
    display: none

  table
    // min-width: fit-content !important
    max-width: -webkit-fill-available
    display: block

    tbody
      display: block
      cursor: pointer

  tr
    // height: 24px
    font-size: inherit
    font-weight: 400
    display: flex
    // margin-left: 8px
    // margin-right: 8px
    border-top: 0.0625em solid EVENT_LOG_ROWS_BORDERS_COLOR
    color: COLOR
    align-items: start
    // padding-right: 8px

    td
      cursor: normal

    .dataTables_empty
      cursor: normal

    &.future
      opacity: 0.5

    &.future:hover
      opacity: 1

    &.odd.past:hover
      background-color: ACTIVE_ROW
      opacity: 1

    &.even.past:hover
      background-color: ACTIVE_ROW
      opacity: 1

    &.odd.future:hover
      background-color: ACTIVE_ROW
      opacity: 1

    &.even.future:hover
      background-color: ACTIVE_ROW
      opacity: 1

    td
      display: grid
      color: EVENT_LOG_CONTENT_COLOR
      font-weight: 400
  td
    text-overflow: clip
  /* max-width: 200px // TODO */

  thead
    display: none

.dt-container
  height: 100%
  display: flex
  flex-direction: column
  min-height: 0

  .dt-length
    display: none

  .dt-scroll
    flex: 1 1 auto
    min-height: 0

  .dt-scroll-body
    min-height: 0

  .dt-scroll-head
    height: 0 !important

  .dt-info
    padding-left: 0.625em

.data-tables-footer
  position: relative
  padding-left: 0.9375em
  height: 1.5em
  font-size: 0.75em
  line-height: 1.5em
  // font-style: italic
  font-family: "SpaceMono"
  color: TEXT_CONTENT_COLOR
  display: flex

  .data-tables-footer-info
    position: relative
    margin-right: 0.625em
    display: flex
    align-items: center

    .data-tables-footer-end-row
      padding-left: 0.5ex
      padding-right: 0.5ex

    .data-tables-footer-rows-count
      padding-left: 0.5ex
      padding-right: 0.5ex

  .data-tables-footer-input
    margin-bottom: 0em !important

  .data-tables-footer-checkbox-container
    position: relative
    height: 100%
    padding-left: 1.25em

