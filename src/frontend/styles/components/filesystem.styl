
.filesystem-container
  height: 100%
  display: flex
  flex-direction: column
  justify-content: space-between

.filesystem
  font-family: "SpaceGrotesk" !important
  font-style: normal !important
  font-weight: 400 !important
  overflow: auto
  //border: 1px solid silver
  min-height: 100px
  height: -webkit-fill-available
  // overflow-y: scroll
  // background-color: BACKGROUND_COLOR
  color: colors-ui-text-default-label
  // margin-left: 2px

  &:focus
    outline: 0px

.filesystem-tree
  min-width: max-content
  padding: 0

.filesystem-entry
  display: grid
  grid-template-columns: 1em 1.35em max-content
  align-items: center
  min-height: 1.55em
  line-height: 1.55em
  cursor: default
  white-space: nowrap

  &:hover
    background-color: ACTIVE_ROW

.filesystem-entry-children
  grid-column: 1 / -1
  padding-left: 1.35em

.filesystem-entry-twisty
  color: TEXT_CONTENT_COLOR
  opacity: 0.85
  text-align: center

.filesystem-entry-icon
  width: 1.1em
  height: 1.1em
  position: relative
  opacity: 0.95

  &.custom-noir-icon::before
    position: static
    transform: none
    width: 1em
    height: 1em

.filesystem-entry-folder-icon
  border: 0.09em solid TEXT_CONTENT_COLOR
  border-radius: 0.12em
  width: 0.95em
  height: 0.7em

  &::before
    content: ""
    position: absolute
    left: 0.08em
    top: -0.28em
    width: 0.45em
    height: 0.25em
    border: 0.09em solid TEXT_CONTENT_COLOR
    border-bottom: 0
    border-radius: 0.12em 0.12em 0 0

.filesystem-entry-file-icon
  border-left: 0.12em solid TEXT_CONTENT_COLOR
  height: 1em

.filesystem-entry-label
  overflow: hidden
  text-overflow: ellipsis

.jstree-anchor
  color: TEXT_CONTENT_COLOR !important

.diff-file-added
  color: green !important

.diff-file-changed
  color: orange !important

.diff-file-deleted
  color: red !important

.diff-files-list
  max-height: 20% !important
  height: auto
  display: flex
  flex-direction: column
  border-top: 4px solid PRIMARY_BASE
  overflow-y: auto
  overflow-x: hidden
  margin-left: 2px
  background-color: PRIMARY_BASE

  &::-webkit-scrollbar-thumb
    border-color: PRIMARY_BASE
    margin-right: 2px

.diff-file-path
  cursor: pointer
  padding-left: 8px

.path-odd
  background: INACTIVE_BASE
.path-even
  background: ACTIVE_ROW
