// DeepReview component styles.
//
// Layout: three-panel design with file list sidebar (left),
// editor area with sliders (center), and call trace panel (right).

.deepreview-container
  display flex
  flex-direction column
  height 100%
  width 100%
  overflow hidden
  font-family 'SpaceGrotesk', sans-serif

// --- Header ---
// Compact header bar (32-36px height) matching CodeTracer status bar style.
// Dark background (#252526), light text (#cccccc).

.deepreview-header
  display flex
  justify-content space-between
  align-items center
  gap 12px
  padding 4px 16px
  min-height 32px
  max-height 36px
  background-color #252526
  border-bottom 1px solid var(--border-color, #3a3b44)
  flex-shrink 0

.deepreview-session-title
  font-size 13px
  font-weight 600
  color #cccccc
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  flex-shrink 1
  min-width 0

.deepreview-commit
  font-size 13px
  color #cccccc

.deepreview-stats
  font-size 12px
  color var(--text-secondary, #8e8f92)

// --- Trace context selector ---
// Dropdown matching the GL tab styling: dark background, light text,
// compact sizing consistent with the header bar height.

.deepreview-trace-selector
  display flex
  align-items center
  flex-shrink 0

.deepreview-trace-select
  font-family 'SpaceGrotesk', sans-serif
  font-size 12px
  color #cccccc
  background-color #3c3c3c
  border 1px solid var(--border-color, #3a3b44)
  border-radius 3px
  padding 2px 8px
  height 24px
  cursor pointer
  outline none
  appearance auto

  &:hover
    background-color #4a4a4a

  &:focus
    border-color #007acc

.deepreview-error
  padding 24px
  font-size 14px
  color var(--text-secondary, #8e8f92)

// --- Body (three-panel layout) ---

.deepreview-body
  display flex
  flex 1
  overflow hidden

// --- File list sidebar ---

.deepreview-file-list
  width 250px
  min-width 180px
  overflow-y auto
  border-right 1px solid var(--border-color, #3a3b44)
  background-color var(--bg-primary, #1a1b22)
  flex-shrink 0

// --- Multi-line file item (legacy / fallback) ---

.deepreview-file-item
  padding 14px 12px
  cursor pointer
  border-bottom 1px solid var(--border-color, #2a2b34)
  transition background-color 0.15s ease

  &:hover
    background-color var(--bg-hover, #2a2b34)

  &.selected
    background-color var(--bg-selected, #333444)

.deepreview-file-name
  font-size 13px
  color var(--text-primary, #c9c9c9)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.deepreview-file-path-full
  font-size 11px
  color var(--text-secondary, #8e8f92)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  margin-top 2px

// --- File name row (status indicator + basename) ---

.deepreview-file-name-row
  display flex
  align-items center
  gap 6px

// --- Diff status indicator badge (A/M/D) ---

.deepreview-diff-status
  display inline-flex
  align-items center
  justify-content center
  width 18px
  height 18px
  font-size 11px
  font-weight bold
  border-radius 3px
  flex-shrink 0
  color var(--text-primary, #c9c9c9)
  background-color var(--bg-hover, #2a2b34)

  &.deepreview-diff-added
    color #3fb950
    background-color rgba(63, 185, 80, 0.15)

  &.deepreview-diff-modified
    color #d29922
    background-color rgba(210, 153, 34, 0.15)

  &.deepreview-diff-deleted
    color #f85149
    background-color rgba(248, 81, 73, 0.15)

// --- File badges row (diff lines + coverage) ---

.deepreview-file-badges
  display flex
  align-items center
  gap 6px
  margin-top 2px

// --- Diff line count badge (+N / -M) ---

.deepreview-diff-lines
  display inline-block
  font-size 11px
  color var(--text-secondary, #8e8f92)
  background-color var(--bg-hover, #2a2b34)
  padding 1px 6px
  border-radius 3px

  &.deepreview-diff-added
    color #3fb950

  &.deepreview-diff-modified
    color #d29922

  &.deepreview-diff-deleted
    color #f85149

.deepreview-coverage-badge
  display inline-block
  font-size 11px
  color var(--text-secondary, #8e8f92)
  background-color var(--bg-hover, #2a2b34)
  padding 1px 6px
  border-radius 3px

// --- Compact one-line-per-file item ---
// Format: [M] main.rs  +8/-3  15/17
// All elements on a single row with inline spacing.

.deepreview-file-item-compact
  display flex
  align-items center
  gap 6px
  padding 4px 10px
  cursor pointer
  border-bottom 1px solid var(--border-color, #2a2b34)
  transition background-color 0.15s ease
  white-space nowrap
  overflow hidden
  min-height 24px

  &:hover
    background-color var(--bg-hover, #2a2b34)

  &.selected
    background-color var(--bg-selected, #333444)

.deepreview-diff-status-compact
  display inline-flex
  align-items center
  justify-content center
  width 16px
  height 16px
  font-size 10px
  font-weight bold
  border-radius 2px
  flex-shrink 0
  color var(--text-primary, #c9c9c9)
  background-color var(--bg-hover, #2a2b34)

  &.deepreview-diff-added
    color #3fb950
    background-color rgba(63, 185, 80, 0.15)

  &.deepreview-diff-modified
    color #d29922
    background-color rgba(210, 153, 34, 0.15)

  &.deepreview-diff-deleted
    color #f85149
    background-color rgba(248, 81, 73, 0.15)

.deepreview-file-name-compact
  font-size 12px
  color var(--text-primary, #c9c9c9)
  overflow hidden
  text-overflow ellipsis
  flex 1
  min-width 0

.deepreview-diff-lines-compact
  font-size 11px
  color var(--text-secondary, #8e8f92)
  flex-shrink 0

  &.deepreview-diff-added
    color #3fb950

  &.deepreview-diff-modified
    color #d29922

  &.deepreview-diff-deleted
    color #f85149

.deepreview-coverage-compact
  font-size 11px
  color var(--text-secondary, #8e8f92)
  flex-shrink 0

// --- Editor area ---

.deepreview-editor-area
  flex 1
  display flex
  flex-direction column
  min-width 0
  overflow hidden

.deepreview-editor
  flex 1
  min-height 0

// --- Sliders ---

.deepreview-slider
  display flex
  align-items center
  gap 8px
  padding 4px 12px
  background-color var(--bg-secondary, #1e1f26)
  border-bottom 1px solid var(--border-color, #3a3b44)
  flex-shrink 0
  font-size 12px
  color var(--text-secondary, #8e8f92)

.deepreview-slider-empty
  opacity 0.5

.deepreview-slider-label
  flex-shrink 0
  min-width 70px

.deepreview-slider-input
  flex 1
  cursor pointer
  accent-color #5b9bd5

  &::-webkit-slider-runnable-track
    background-color #3c3c3c
    border-radius 2px

  &::-webkit-slider-thumb
    background-color #5b9bd5

.deepreview-slider-info
  flex-shrink 0
  min-width 100px
  text-align right

// --- Call trace panel ---

.deepreview-calltrace
  width 280px
  min-width 200px
  overflow-y auto
  border-left 1px solid #3c3c3c
  background-color var(--bg-primary, #1a1b22)
  flex-shrink 0

.deepreview-calltrace-header
  padding 8px 12px
  font-size 13px
  font-weight bold
  color var(--text-primary, #c9c9c9)
  border-bottom 1px solid var(--border-color, #3a3b44)
  background-color var(--bg-secondary, #1e1f26)

.deepreview-calltrace-body
  padding 4px 0

.deepreview-calltrace-empty
  padding 12px
  font-size 12px
  color var(--text-secondary, #8e8f92)
  font-style italic

.deepreview-calltrace-node
  font-size 12px

.deepreview-calltrace-entry
  padding 3px 8px
  cursor default

  &:hover
    background-color var(--bg-hover, #2a2b34)

.deepreview-calltrace-name
  color var(--text-primary, #c9c9c9)

.deepreview-calltrace-count
  color var(--text-secondary, #8e8f92)
  font-size 11px

// --- View mode toggle ---

.deepreview-mode-toggle
  display flex
  align-items center
  gap 0

.deepreview-mode-btn
  padding 3px 12px
  font-size 12px
  font-family 'SpaceGrotesk', sans-serif
  color var(--text-secondary, #8e8f92)
  background-color transparent
  border 1px solid var(--border-color, #3a3b44)
  cursor pointer
  transition background-color 0.15s ease, color 0.15s ease

  &:first-child
    border-radius 3px 0 0 3px

  &:last-child
    border-radius 0 3px 3px 0
    border-left none

  &:hover
    background-color var(--bg-hover, #2a2b34)
    color var(--text-primary, #c9c9c9)

  &.deepreview-mode-btn-active
    background-color var(--bg-selected, #333444)
    color var(--text-primary, #c9c9c9)
    border-color var(--border-color, #3a3b44)

// --- Unified diff view ---

.deepreview-unified-diff
  flex 1
  overflow-y auto
  padding 0

.deepreview-unified-empty
  padding 24px
  font-size 13px
  color var(--text-secondary, #8e8f92)
  font-style italic

.deepreview-unified-file
  margin-bottom 0
  border-bottom 1px solid var(--border-color, #3a3b44)

.deepreview-unified-file-header
  display flex
  align-items center
  gap 8px
  padding 6px 12px
  background-color var(--bg-secondary, #1e1f26)
  border-bottom 1px solid var(--border-color, #3a3b44)
  font-size 13px

.deepreview-unified-file-path
  color var(--text-primary, #c9c9c9)
  font-family 'JetBrains Mono', 'FiraMono', 'Cascadia Code', monospace
  font-size 12px

.deepreview-unified-file-stats
  display flex
  gap 6px
  margin-left auto
  font-size 12px

.deepreview-unified-additions
  color #3fb950

.deepreview-unified-deletions
  color #f85149

.deepreview-unified-hunk
  font-family 'JetBrains Mono', 'FiraMono', 'Cascadia Code', monospace
  font-size 12px
  line-height 20px

.deepreview-unified-hunk-header
  padding 2px 12px
  color var(--text-secondary, #8e8f92)
  background-color rgba(56, 58, 68, 0.4)
  font-size 11px
  user-select none

.deepreview-unified-line
  display flex
  align-items stretch
  min-height 20px

.deepreview-unified-line-added
  background-color rgba(63, 185, 80, 0.10)

.deepreview-unified-line-removed
  background-color rgba(248, 81, 73, 0.10)

.deepreview-unified-line-context
  background-color transparent

.deepreview-unified-gutter-old
.deepreview-unified-gutter-new
  display inline-block
  width 48px
  min-width 48px
  text-align right
  padding-right 8px
  color var(--text-secondary, #6e7681)
  user-select none
  border-right 1px solid var(--border-color, #2a2b34)
  flex-shrink 0
  font-size 11px
  line-height 20px

.deepreview-unified-line-prefix
  display inline-block
  width 16px
  min-width 16px
  text-align center
  color var(--text-secondary, #8e8f92)
  user-select none
  flex-shrink 0
  font-size 11px
  line-height 20px

.deepreview-unified-line-added .deepreview-unified-gutter-old
.deepreview-unified-line-added .deepreview-unified-gutter-new
.deepreview-unified-line-added .deepreview-unified-line-prefix
  background-color rgba(63, 185, 80, 0.06)

.deepreview-unified-line-removed .deepreview-unified-gutter-old
.deepreview-unified-line-removed .deepreview-unified-gutter-new
.deepreview-unified-line-removed .deepreview-unified-line-prefix
  background-color rgba(248, 81, 73, 0.06)

.deepreview-unified-line-content
  flex 1
  padding-left 12px
  white-space pre
  overflow-x auto
  color var(--text-primary, #c9c9c9)
  line-height 20px

.deepreview-unified-line-added .deepreview-unified-line-content
  color #3fb950

.deepreview-unified-line-removed .deepreview-unified-line-content
  color #f85149

// --- Context expansion buttons ---

.deepreview-expand-row
  display flex
  align-items center
  gap 6px
  padding 1px 12px
  cursor pointer
  user-select none
  color var(--text-secondary, #6e7681)
  font-family 'JetBrains Mono', 'FiraMono', 'Cascadia Code', monospace
  font-size 11px
  line-height 20px
  background-color transparent
  transition color 0.15s ease, background-color 0.15s ease

  &:hover
    color var(--text-primary, #c9c9c9)
    background-color rgba(56, 58, 68, 0.3)

.deepreview-expand-icon
  color var(--text-secondary, #6e7681)
  width 48px
  min-width 48px
  text-align center
  flex-shrink 0

.deepreview-expand-label
  color inherit

// --- Expanded context lines (slightly dimmer than normal context) ---

.deepreview-expanded-context
  opacity 0.75

// --- Coverage line highlighting (Monaco decorations) ---

.deepreview-line-executed
  background-color rgba(0, 180, 0, 0.08)
  border-left 3px solid rgba(0, 200, 0, 0.5)

.deepreview-line-unreachable
  background-color rgba(220, 0, 0, 0.08)
  border-left 3px solid rgba(220, 0, 0, 0.5)

.deepreview-line-partial
  background-color rgba(220, 180, 0, 0.08)
  border-left 3px solid rgba(220, 180, 0, 0.5)

// --- Diff line highlighting (Monaco decorations for Full Files mode) ---
// Uses the same green/yellow palette as the unified diff view for
// visual consistency. Only added and modified lines are decorated
// (removed lines have no position in the new file version).

.deepreview-diff-line-added
  background-color rgba(63, 185, 80, 0.18)
  border-left 3px solid #3fb950

.deepreview-diff-line-modified
  background-color rgba(210, 153, 34, 0.18)
  border-left 3px solid #d29922

// --- Inline variable values (Monaco afterContent decorations) ---

// Monaco afterContent injection for Full Files mode. Cannot use nested DOM
// (only a flat text span), so we approximate the flow-parallel-value-box
// appearance: same background, colour, font and border-radius.
.deepreview-inline-value
  background-color FLOW_INLINE_BEFORE_ONLY_VALUE_BACKGROUND_COLOR
  color FLOW_INLINE_BEFORE_ONLY_VALUE_COLOR
  font-family 'FiraMono', monospace
  font-size 12px
  padding-left 5px
  padding-right 5px
  border-radius 2px
  margin-left 16px
  white-space nowrap

// --- Omniscience overlay (inline variable values on unified diff lines) ---
//
// Reuses the standard CodeTracer flow visualization CSS classes
// (flow-parallel-value, flow-parallel-value-name, flow-parallel-value-box,
// flow-parallel-value-before-only) so annotations in the unified diff look
// identical to flow annotations in the Monaco editor.
//
// The wrapper class below positions the flow value widgets inline after the
// code content within each diff line and adjusts sizing for the diff context.

.deepreview-flow-values
  display inline-flex
  margin-left 16px
  flex-shrink 0
  align-items center
  gap 2px
  user-select none

  .flow-parallel-value
    display inline-flex
    padding-right 6px

  .flow-parallel-value-name
    padding-left 6px
    padding-right 6px

  .flow-parallel-value-box
    max-width 30ch

// --- Diff line highlighting for standard editor in DeepReview mode ---
// These classes are applied by the editor's ``deepReviewDiffStyleLines``
// via the existing ``styleLines`` / ``deltaDecorations`` pattern when a
// file is opened in DeepReview mode and has diff hunk data.

.line-diff-added
  background-color rgba(63, 185, 80, 0.18)
  border-left 3px solid #3fb950

.line-diff-modified
  background-color rgba(210, 153, 34, 0.18)
  border-left 3px solid #d29922

.line-diff-removed
  background-color rgba(248, 81, 73, 0.18)
  border-left 3px solid #f85149

// --- Monaco editor overrides for DeepReview ---
// Brighten gutter line numbers for better readability in the dark theme.

.deepreview-editor-area .line-numbers
  color #999999 !important
