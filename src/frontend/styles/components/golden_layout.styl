
.lm_goldenlayout
  background: colors-ui-surface-primary-default !important
  // border-right: 1px solid PRIMARY_BASE

.lm_header
  background-color: transparent !important
  color: HEADER_PANEL_COLOR !important
  position: relative
  // height: 2em !important
  box-shadow: 2px 0 0 0 HEADER_PANEL_BACKGROUND_COLOR !important
  z-index: 3 !important

.lm_splitter
  background: colors-ui-surface-primary-default !important
  opacity: unset !important
  transition: background 150ms ease !important
  z-index: 4 !important
  cursor: col-resize

  &.lm_vertical
    cursor: row-resize

  &:hover
    background: colors-ui-border-interactive-default !important

.lm_stack
  overflow: hidden !important

.lm_tabs
  width: 100%
  display: flex

.lm_splitter.lm_dragging
  background: #444444;
  z-index: 11

.lm_tab
  font-family: "SpaceGrotesk" !important
  font-size: inherit !important
  font-style: normal
  font-weight: 600 !important
  letter-spacing: -0.14px !important
  //height: 25px !important
  background-color: colors-ui-surface-panel !important
  color: colors-ui-text-default-tab !important
  margin: 0 !important
  border: 0 !important
  // margin-top: 2px !important
  // padding-top: 2px !important
  // padding-bottom: 2px !important
  padding: 0.38em 0.5em !important
  box-shadow: none !important
  line-height: normal !important
  // max-width: min(200px, 30%)
  overflow: hidden
  border-radius: 0.36em
  // margin-left: 2px !important
  margin-right: 0.24em !important
  margin-bottom: 0px !important
  flex: 1
  text-align: center
  display: flex !important
  align-items: center !important
  // box-sizing: border-box

.lm_tabdropdown::before
  color: LAYOUT_DROPDOWN_ICON_COLOR !important
  vertical-align: text-top !important

.lm_item
  background-color: transparent !important
  // outline: 1px solid LAYOUT_SPLITTER_COLOR !important
  z-index: 3 !important

.lm_items
  // transform: translateX(-2px)
  // box-shadow: inset -1px 0 0 0 LAYOUT_SPLITTER_COLOR
  // width: calc(100% - 6px)
  border-radius: 0.36em

.lm_content
  background-color: colors-ui-surface-panel !important
  // box-shadow: inset 2px 0px 0px 0px LAYOUT_SPLITTER_COLOR
  border: 0 !important
  // padding-top: 8px
  border-radius: 0.36em
  font-size: inherit
  padding: 0.5em 0em 0em 0em
  // padding-right: 2px
  // margin-left: 2px
  // padding-right: 10px

.lm_items
  background-color: transparent
  // outline: 2px solid PRIMARY_BASE

.lm_splitter.lm_horizontal
  width: 4px !important

.lm_splitter.lm_vertical
  height: 4px !important

.lm_splitter.lm_vertical .lm_drag_handle
  top: 0 !important
  height: 2px !important
  background-color: colors-ui-surface-primary-default

.lm_splitter.lm_horizontal .lm_drag_handle
  //left: -5px
  left: 0 !important
  width: 4px !important
  background-color: colors-ui-surface-primary-default

.lm_title
  color: HEADER_PANEL_COLOR !important
  // font-family: sans-serif !important
  font-weight: 500 !important
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  width: 100%
  padding-top: 0em !important
  text-align: start !important
// direction: rtl

.lm_active
  background-color: colors-ui-surface-panel !important
  //border-radius: 2px
  border-top-left-radius: 0.36em
  border-top-right-radius: 0.36em
  border-bottom-right-radius: 0em
  border-bottom-left-radius: 0em
  box-shadow: 0em 0.48em 0em 0em colors-ui-surface-panel !important
  overflow: visible !important

  &::before
    content: " ";
    pointer-events: none;
    position: absolute;
    display: block;
    height: 80%;
    width: 1.625em
    bottom: 0em
    z-index: 1
    left: -1.625em
    border-radius: 0 0 0.625em 0
    opacity: 1
    box-shadow: 0.625em 0.34em 0 -0.25em colors-ui-surface-panel
    transform: translate(0em, 0.25625em)

  &::after
    content: " ";
    pointer-events: none;
    position: absolute;
    display: block;
    height: 80%;
    width: 1.625em
    bottom: 0em
    z-index: 1
    right: -1.625em
    border-radius: 0 0 0 0.625em
    opacity: 1
    box-shadow: -0.625em 0.34em 0 -0.25em colors-ui-surface-panel
    transform: translate(0em, 0.25625em)

.lm_header .lm_active .lm_title
  color: HEADER_ACTIVE_PANEL_TEXT_COLOR !important

.lm_header .lm_controls
  height: 100% !important
  align-items: center !important

.lm_controls > *
  // Secondary button style — matches [class*="-button-"][class*="-secondary"] in button.styl
  opacity: 1 !important
  background-color: colors-ui-surface-primary-default !important
  border: 0.03125em solid colors-ui-border-primary !important
  border-radius: 0.375em !important
  background-position: center !important
  background-repeat: no-repeat !important
  background-size: 1em 1em !important
  width: 1.5em !important
  height: 1.5em !important
  cursor: pointer

  &:focus
    outline: none !important
    box-shadow: none !important

  &:focus-visible
    outline: none !important
    box-shadow: inset 0 0 0 0.125em colors-ui-border-focus !important

  &:hover
    background-color: colors-ui-surface-primary-default-hover !important

.lm_maximise
  background-image: LAYOUT_MAXIMIZE_ICON_PATH !important

.lm_popout
  display: none !important

.lm_close
  background-image: LAYOUT_CLOSE_ICON_PATH !important

/* based on https://codepen.io/sosuke/pen/Pjoqqp : CSS filter generator to convert from black to target hex color
    Barrett Sonntag  found from
    https://stackoverflow.com/a/53336754/438099
  */
// converts to white
// .menu-button-svg, .menu-node-svg
//   filter: MENU_BUTTON_SVG_FILTER

.lm_header .lm_tab .lm_close_tab
  background-image: LAYOUT_TAB_CLOSE_ICON_PATH !important
  width: 0.6em !important
  height: 0.6em !important
  background-size: 0.6em 0.6em
  position: static !important
  opacity: 1 !important

.lm_header .lm_tab .lm_pin_tab
  background-image: LAYOUT_TAB_PIN_ICON_PATH !important
  background-repeat: no-repeat
  background-position: center
  background-size: 0.85em 0.85em
  width: 0.85em !important
  height: 0.85em !important
  position: static !important
  cursor: pointer
  margin-right: 0.3em
  opacity: 0.7
  flex-shrink: 0

  &:hover
    opacity: 1

.lm_header .lm_tab
  height: 1.01em !important
