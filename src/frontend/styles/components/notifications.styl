@import "../generated/index"

.status-notification.ct-notification
  display: flex
  flex-direction: column
  align-items: stretch
  width: 29.125rem
  max-width: calc(100vw - 1rem)
  position: relative
  box-sizing: border-box
  border: 0.0625rem solid transparent
  border-radius: 0.5rem
  padding: 0.75rem 0.875rem
  gap: 0.75rem
  background-color: colors-ui-surface-primary-default
  color: colors-ui-text-primary-body

  &[class*="-tertiary"]
    width: auto
    max-width: 29.125rem
    margin: 0
    padding: 0
    gap: 0.375rem
    border-color: transparent
    border-radius: 0
    background-color: transparent

  .notification-wrapper
    display: flex
    align-items: flex-start
    width: 100%
    gap: 0.625rem

  .notification-icon
    width: 1.125rem
    min-width: 1.125rem
    height: 1.125rem
    min-height: 1.125rem
    background-repeat: no-repeat
    background-size: 1.125rem
    background-position: center
    margin-top: 0.125rem

    &.info
      background-image: ct-images-notification-info

    &.warning
      background-image: ct-images-notification-warning

    &.error
      background-image: ct-images-notification-error

    &.success
      background-image: ct-images-notification-success

  .notification-message
    flex: 1
    min-width: 0
    color: inherit
    font-family: "SpaceMono"
    font-size: 0.875rem
    font-weight: 400
    letter-spacing: -0.01em
    line-height: 1.5
    white-space: pre-wrap
    overflow-wrap: anywhere

  .notification-button
    flex: 0 0 auto
    width: 1.125rem
    min-width: 1.125rem
    height: 1.125rem
    min-height: 1.125rem
    cursor: pointer
    user-select: none
    opacity: 0.72
    background-image: ct-images-close-button
    background-repeat: no-repeat
    background-position: center
    background-size: 0.875rem
    border-radius: 0.25rem

    &:hover
      opacity: 1

  .notification-action-wrapper
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 0.5rem
    padding-left: 1.75rem

  .notification-action-button
    display: inline-flex
    align-items: center
    justify-content: center
    width: fit-content
    min-height: 1.75rem
    padding: 0 0.75rem
    border: 0.0625rem solid currentColor
    border-radius: 999px
    background-color: transparent
    color: inherit
    cursor: pointer
    user-select: none
    font-family: "SpaceMono"
    font-size: 0.8125rem
    line-height: 1.2

    &:hover
      opacity: 0.85

.status-notification.ct-notification.ct-notification-info-primary
  border-color: colors-ui-border-information
  background-color: colors-ui-surface-primary-default
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-warning-primary
  border-color: colors-ui-border-warning
  background-color: colors-ui-surface-primary-default
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-error-primary
  border-color: colors-ui-border-error
  background-color: colors-ui-surface-primary-default
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-success-primary
  border-color: colors-ui-border-success
  background-color: colors-ui-surface-primary-default
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-info-secondary
  border-color: colors-ui-surface-alert-information
  background-color: colors-ui-surface-alert-information
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-warning-secondary
  border-color: colors-ui-surface-alert-warning
  background-color: colors-ui-surface-alert-warning
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-error-secondary
  border-color: colors-ui-surface-alert-error
  background-color: colors-ui-surface-alert-error
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-success-secondary
  border-color: colors-ui-surface-alert-success
  background-color: colors-ui-surface-alert-success
  color: colors-ui-text-primary-body

.status-notification.ct-notification.ct-notification-info-tertiary
  color: colors-ui-text-information-primary

.status-notification.ct-notification.ct-notification-warning-tertiary
  color: colors-ui-text-warning-primary

.status-notification.ct-notification.ct-notification-error-tertiary
  color: colors-ui-text-error-primary

.status-notification.ct-notification.ct-notification-success-tertiary
  color: colors-ui-text-success-primary
