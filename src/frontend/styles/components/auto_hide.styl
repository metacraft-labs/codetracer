// Auto-hide panes: edge strips, strip tabs, overlay, and backdrop.
// Styling follows Visual Studio's auto-hide behavior: overlays are flush
// with window edges, no border-radius, and side strip tabs use vertical text.
//
// Layout: side strips tile WITH the GL container in a flex row, so the GL
// area shrinks to accommodate them (no overlay on top of content).
// Bottom auto-hide labels render inside #status-base (the footer).

// ---------------------------------------------------------------------------
// Layout row — flex container that holds left strip, GL (#ROOT), right strip.
// ---------------------------------------------------------------------------

#auto-hide-layout-row
  display: flex
  flex-direction: row
  flex: 1
  min-height: 0
  width: 100%

// ---------------------------------------------------------------------------
// Side edge strips — flex items that sit beside #ROOT.
// Width is 0 when empty (no tabs), 28px when populated.
// ---------------------------------------------------------------------------

#auto-hide-strip-left,
#auto-hide-strip-right
  display: flex
  flex-direction: column
  align-items: center
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  flex-shrink: 0
  flex-grow: 0
  flex-basis: 0
  width: 0
  max-width: 0
  overflow: hidden
  transition: width 150ms ease, max-width 150ms ease, padding 150ms ease
  // Ensure strips sit above GL's absolutely-positioned internal elements
  // so strip tabs remain clickable.
  position: relative
  z-index: 2

  // Expand to 28px when the strip has tabs (class toggled by auto_hide.nim).
  &.has-tabs
    width: 28px
    min-width: 28px
    max-width: 28px
    flex-basis: 28px
    padding-top: 4px

#auto-hide-strip-left.has-tabs
  border-right: 1px solid PRIMARY_BASE

#auto-hide-strip-right.has-tabs
  border-left: 1px solid PRIMARY_BASE

// ---------------------------------------------------------------------------
// Collapsed mode — 1px accent line when maximized on bounded screen edge.
// ---------------------------------------------------------------------------

#auto-hide-strip-left.collapsed-mode,
#auto-hide-strip-right.collapsed-mode
  width: 3px
  min-width: 3px
  max-width: 3px
  flex-basis: 3px
  padding-top: 0
  background-color: #3a5070  // Subtle blue accent — distinct from panel bg
  cursor: pointer
  overflow: hidden

#auto-hide-strip-left.collapsed-mode
  border-right: none

#auto-hide-strip-right.collapsed-mode
  border-left: none

// The collapsed strip line is the clickable target inside the strip.
.collapsed-strip-line
  width: 100%
  height: 100%
  cursor: pointer

  &:hover
    background-color: #4a6080  // Slightly lighter on hover

// ---------------------------------------------------------------------------
// Bottom auto-hide tabs — rendered inside #status-base (the footer).
// Styled as inline status-bar items on the left side.
// ---------------------------------------------------------------------------

.auto-hide-bottom-tabs
  display: flex
  flex-direction: row
  align-items: center
  gap: 0.125em
  margin-left: 0.5em
  min-width: 0
  height: 100%

  // Hide when empty so it doesn't affect status bar layout.
  &:empty
    display: none

// ---------------------------------------------------------------------------
// Strip tabs — individual clickable tabs within a strip.
// ---------------------------------------------------------------------------

.auto-hide-strip-tab
  font-family: "SpaceMono"
  font-size: 12px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  background-color: HEADER_PANEL_INACTIVE_COLOR
  border-radius: 0
  cursor: pointer
  padding: 3px 6px
  margin: 2px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

  &.active
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

// Side strip tabs: VS Studio uses vertical text (rotated 90deg).
// Left side: text reads bottom-to-top (vertical-lr + rotate).
#auto-hide-strip-left .auto-hide-strip-tab
  writing-mode: vertical-lr
  text-orientation: mixed
  transform: rotate(180deg)
  max-height: 120px

// Right side: text reads top-to-bottom (vertical-rl).
#auto-hide-strip-right .auto-hide-strip-tab
  writing-mode: vertical-rl
  text-orientation: mixed
  max-height: 120px

// Bottom tabs in the status bar use the shared button primitives instead of
// the legacy strip-tab div styling. Keep the sizing relative to the inherited
// font size so the bar scales cleanly with zoom.
.auto-hide-bottom-tab
  flex: 0 1 auto !important
  min-width: 0
  max-width: 14em
  height: 1.833em
  margin: 0
  padding-left: 0.833em
  padding-right: 0.833em
  border-radius: 0.333em !important
  align-self: center
  box-sizing: border-box
  font-size: 0.6em
  font-weight: 600
  line-height: 1.2
  letter-spacing: 0
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

  &:hover
  &.active
    color: colors-ui-text-primary-body
    background-color: colors-ui-surface-primary-tertiary-hover !important

// ---------------------------------------------------------------------------
// Backdrop — semi-transparent overlay behind the slide-in panel.
// ---------------------------------------------------------------------------

#auto-hide-backdrop
  display: none
  position: fixed
  top: 0
  left: 0
  right: 0
  bottom: 0
  background-color: rgba(0, 0, 0, 0.25)
  z-index: 98

#auto-hide-overlay.visible ~ #auto-hide-backdrop
  display: block

// ---------------------------------------------------------------------------
// Overlay — the slide-in panel that appears when a strip tab is clicked.
// Flush with the window edge, no border-radius, no margin/padding gap.
// ---------------------------------------------------------------------------

#auto-hide-overlay
  position: fixed
  z-index: 99
  background-color: SECONDARY_BASE
  border: none
  border-radius: 0
  box-shadow: none
  margin: 0
  padding: 0
  display: none
  flex-direction: column
  overflow: hidden
  transition: transform 200ms ease

  &.visible
    display: flex

// Edge-specific positioning: each overlay is flush with its edge and
// spans the full available dimension along that edge.

// Left overlay: flush with left edge, full height (menu bar to bottom window edge).
// Only the right edge gets a border (separator from main content).
#auto-hide-overlay.auto-hide-overlay-left
  top: 34px
  left: 0
  bottom: 0
  width: 360px
  border-right: 1px solid PRIMARY_BASE

// Right overlay: flush with right edge, full height (menu bar to bottom window edge).
// Only the left edge gets a border.
#auto-hide-overlay.auto-hide-overlay-right
  top: 34px
  right: 0
  bottom: 0
  width: 360px
  border-left: 1px solid PRIMARY_BASE

// Bottom overlay: flush with bottom window edge, full width.
// Only the top edge gets a border.
#auto-hide-overlay.auto-hide-overlay-bottom
  left: 0
  right: 0
  bottom: 0
  height: 280px
  border-top: 1px solid PRIMARY_BASE

// ---------------------------------------------------------------------------
// Overlay header
// ---------------------------------------------------------------------------

#auto-hide-overlay-header
  display: flex
  align-items: center
  justify-content: space-between
  padding: 4px 8px
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  border-bottom: 1px solid PRIMARY_BASE
  min-height: 32px
  flex-shrink: 0

#auto-hide-overlay-title
  font-family: "SpaceMono"
  font-size: 13px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex: 1

.auto-hide-overlay-header-buttons
  display: flex
  gap: 4px
  align-items: center

#auto-hide-overlay-unpin-btn,
#auto-hide-overlay-close-btn
  cursor: pointer
  font-size: 12px
  padding: 2px 8px
  border-radius: 0
  color: HEADER_PANEL_COLOR
  background-color: transparent
  border: 1px solid PRIMARY_BASE
  transition: background-color 150ms ease

  &:hover
    background-color: ACTIVE_ROW

// ---------------------------------------------------------------------------
// Overlay content area
// ---------------------------------------------------------------------------

#auto-hide-overlay-content
  flex: 1
  overflow: auto
  padding: 0
  position: relative  // Anchor for the floating pin button

// ---------------------------------------------------------------------------
// Collapsed-mode overlay: hide the full header row and show a small
// floating pin/unpin button in the upper-right corner instead.
// The panel title is already visible in the side-edge tab bar.
// ---------------------------------------------------------------------------

#auto-hide-overlay.collapsed-overlay #auto-hide-overlay-header
  display: none

// Floating pin button — appears only in collapsed-overlay mode.
.overlay-floating-pin
  position: absolute
  top: 4px
  right: 4px
  z-index: 5
  cursor: pointer
  font-size: 14px
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  border-radius: 3px
  color: HEADER_PANEL_COLOR
  background-color: rgba(40, 40, 40, 0.7)
  border: 1px solid PRIMARY_BASE
  transition: background-color 150ms ease
  opacity: 0.6

  &:hover
    background-color: ACTIVE_ROW
    opacity: 1.0

// ---------------------------------------------------------------------------
// Collapsed-mode icon zone — rendered in the status bar.
// Uses the same accent color as the collapsed strip line.
// ---------------------------------------------------------------------------

.collapsed-icon-zone
  display: none

// The icon zone sits at the very left of the status bar, flush with the
// left edge so it visually connects with the collapsed side strip above.
// No margin-left, no border-radius on the left side.
.collapsed-icon-zone.has-icons
  display: flex
  flex-direction: row
  align-items: center
  gap: 2px
  margin: 0
  padding: 0 6px
  background-color: #3a5070  // Same accent as collapsed strip
  border-radius: 0 3px 3px 0  // Rounded only on the right
  height: 100%  // Full status bar height for seamless connection
  align-self: stretch

.collapsed-icon
  font-size: 14px
  cursor: pointer
  padding: 1px 3px
  border-radius: 2px
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: #4a6080

// ---------------------------------------------------------------------------
// Side-edge tabs — VS Studio style, inside the overlay.
// Rendered as a vertical strip between the screen edge and overlay content.
// ---------------------------------------------------------------------------

.overlay-side-tabs
  display: flex
  flex-direction: column
  flex-shrink: 0
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  padding-top: 4px
  gap: 2px
  overflow: hidden

  &.hidden
    display: none

// Left-edge tabs: between screen left edge and overlay content.
// Background matches the overlay, border only on the content side.
.overlay-side-tabs.side-tabs-left
  width: 28px
  min-width: 28px
  border-right: 1px solid PRIMARY_BASE
  order: -1  // Place before overlay content in flex row
  background-color: SECONDARY_BASE  // Match overlay background

// Right-edge tabs: between overlay content and screen right edge.
.overlay-side-tabs.side-tabs-right
  width: 28px
  min-width: 28px
  border-left: 1px solid PRIMARY_BASE
  order: 1  // Place after overlay content in flex row
  background-color: SECONDARY_BASE

.overlay-side-tab
  writing-mode: vertical-lr
  text-orientation: mixed
  transform: rotate(180deg)
  font-family: "SpaceMono"
  font-size: 12px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  background-color: HEADER_PANEL_INACTIVE_COLOR
  cursor: pointer
  padding: 3px 6px
  margin: 2px
  max-height: 120px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

  &.active
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

// Right-edge tabs read top-to-bottom (no rotation).
.side-tabs-right .overlay-side-tab
  writing-mode: vertical-rl
  transform: none
