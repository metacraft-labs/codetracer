// Auto-hide panes: edge strips, strip tabs, overlay, and backdrop.
// Styling follows Visual Studio's auto-hide behavior: overlays are flush
// with window edges, no border-radius, and side strip tabs use vertical text.
//
// Layout: side strips tile WITH the GL container in a flex row, so the GL
// area shrinks to accommodate them (no overlay on top of content).
// Bottom auto-hide tabs render in #status-base (2rem tall, tabs only).

// ---------------------------------------------------------------------------
// Layout row — flex container that holds left strip, GL (#ROOT), right strip.
// ---------------------------------------------------------------------------

#auto-hide-layout-row
  display: flex
  flex-direction: row
  flex: 1
  min-height: 0
  width: 100%

// ---------------------------------------------------------------------------
// Side edge strips — flex items that sit beside #ROOT.
// Width is 0 when empty (no tabs), 2em when populated.
// overflow: visible is required so active-tab curves bleed outside the strip.
// ---------------------------------------------------------------------------

#auto-hide-strip-left,
#auto-hide-strip-right
  display: flex
  flex-direction: column
  align-items: stretch
  background-color: colors-ui-surface-base-canvas
  flex-shrink: 0
  flex-grow: 0
  flex-basis: 0
  width: 0
  max-width: 0
  overflow: visible
  // box-sizing: border-box so that padding is included in the 2em width,
  // keeping the strip's outer edge at exactly 2em from the window edge.
  // This mirrors how lm_header sets the tab HEIGHT via the container:
  // the tab width is determined entirely by the container (strip padding),
  // not by the tab's own margins — so no tab property change can shift content.
  box-sizing: border-box
  transition: width 150ms ease, max-width 150ms ease, padding 150ms ease
  // Strips must sit ABOVE the overlay (z-index 99) so that the active-tab
  // curves (pseudo-elements) are visible against the overlay background.
  position: relative
  z-index: 100

  // Expand to 2em when the strip has tabs (class toggled by auto_hide.nim).
  // padding-left/right create the 0.25em breathing room on each side —
  // the tab fills the content area (1.5em) via align-items: stretch.
  &.has-tabs
    width: 2em
    min-width: 2em
    max-width: 2em
    flex-basis: 2em
    padding-left: 0.25em
    padding-right: 0.25em

// When the left strip is visible, nullify #ROOT's padding-left so the visual
// gap on both sides of the strip tabs is a consistent 0.25em:
//   left:  strip padding-left  (0.25em) from viewport edge to tab left edge
//   right: strip padding-right (0.25em) from tab right edge to GL content
// Without this, ROOT's own padding-left adds a second 0.25em on the right.
#auto-hide-strip-left.has-tabs ~ #ROOT
  padding-left: 0

// Mirror for the right strip: #ROOT appears before #auto-hide-strip-right in
// the flex row so ~ cannot be used.  Use :has() (Chromium 105+ / current
// Electron) to select #ROOT when its sibling right strip has tabs, removing
// ROOT's own padding-right to avoid a double gap between GL and the strip.
#auto-hide-layout-row:has(#auto-hide-strip-right.has-tabs) #ROOT
  padding-right: 0

// ---------------------------------------------------------------------------
// Docked sidebars — shown on click, pushes GL content sideways.
// Hidden by default; `.docked-open` class shows them with a default width.
// A drag handle on the inner edge lets the user resize.
// ---------------------------------------------------------------------------

#auto-hide-docked-left,
#auto-hide-docked-right
  display: none
  flex-direction: column
  flex-shrink: 0
  flex-grow: 0
  background-color: colors-ui-surface-panel
  position: relative
  // z-index: 5 creates a stacking context so GL children with high z-index
  // are confined within it — the backdrop (z-index: 98, transparent) is below
  // both the docked panels and the overlay and serves only as a click-to-dismiss
  // target.
  z-index: 5
  min-width: 150px
  max-width: 800px
  overflow: hidden

  &.docked-open
    display: flex
    width: 360px  // default; overridden by JS resize
    // Raise above the side strip (z-index: 100) so the docked GL content covers
    // the active-tab box-shadow that extends horizontally into this area.
    // Matches the hover overlay z-index (101) for identical visual behaviour.
    z-index: 101

// No border on docked panels — the resize handle acts as the divider,
// matching GL's .lm_splitter which is a solid-background 4px wide element.

#auto-hide-docked-left-content,
#auto-hide-docked-right-content
  flex: 1
  overflow: auto
  min-height: 0
  position: relative

// Push content away from the resize handle so it isn't obscured by the 4px grip.
#auto-hide-docked-left-content
  padding-right: 4px

#auto-hide-docked-right-content
  padding-left: 4px

// Resize grip on the inner edge of each docked panel.
// Matches GL's .lm_splitter exactly: solid 4px background, hover highlight,
// drag highlight — no border, no gradient, same cursor and transition.
.auto-hide-docked-resize-handle
  position: absolute
  top: 0
  bottom: 0
  width: 4px
  cursor: col-resize
  z-index: 10
  flex-shrink: 0
  background: colors-ui-surface-primary-default
  opacity: unset
  transition: background 150ms ease

  &:hover,
  &.resizing
    background: colors-ui-border-interactive-default

// Left docked panel: grip is on its RIGHT edge
#auto-hide-docked-left .auto-hide-docked-resize-handle
  right: 0
  left: auto

// Right docked panel: grip is on its LEFT edge
#auto-hide-docked-right .auto-hide-docked-resize-handle
  left: 0
  right: auto

// ---------------------------------------------------------------------------
// Collapsed mode — 1px accent line when maximized on bounded screen edge.
// ---------------------------------------------------------------------------

#auto-hide-strip-left.collapsed-mode,
#auto-hide-strip-right.collapsed-mode
  width: 3px
  min-width: 3px
  max-width: 3px
  flex-basis: 3px
  padding-top: 0
  padding-left: 0
  padding-right: 0
  background-color: #3a5070  // Subtle blue accent — distinct from panel bg
  cursor: pointer
  overflow: hidden
  align-items: center

#auto-hide-strip-left.collapsed-mode
  border-right: none

#auto-hide-strip-right.collapsed-mode
  border-left: none

// The collapsed strip line is the clickable target inside the strip.
.collapsed-strip-line
  width: 100%
  height: 100%
  cursor: pointer

  &:hover
    background-color: #4a6080  // Slightly lighter on hover

// ---------------------------------------------------------------------------
// Docked bottom panel — pushes GL up when a bottom strip tab is clicked.
// Sits between #auto-hide-layout-row and the footer in the flex column.
// ---------------------------------------------------------------------------

#auto-hide-docked-bottom
  display: none
  flex-direction: column
  flex-shrink: 0
  flex-grow: 0
  background-color: colors-ui-surface-panel
  position: relative
  z-index: 5  // same as side docked panels — keeps panel children below backdrop (98)
  min-height: 100px
  max-height: 600px
  overflow: hidden
  // Inset left/right to match #ROOT's padding-left/right (0.25em) so the panel
  // content aligns with the GL content area rather than being edge-to-edge.
  // margin instead of width: 100% so the flex container controls the width.
  margin-left: 0.25em
  margin-right: 0.25em

  &.docked-open
    display: flex
    height: 280px  // default; overridden by JS resize
    // Raise above the tab strip (z-index: 100) so the docked GL content covers
    // the active-tab box-shadow and curves that extend upward into this area.
    // Without this, the shadow paints ON TOP of the GL content as a visible
    // artifact — especially when the panel has a scrollbar.
    // Matches the hover overlay z-index (101) for identical visual behaviour.
    z-index: 101

#auto-hide-docked-bottom-content
  flex: 1
  overflow: auto
  min-width: 0
  position: relative
  padding-top: 4px  // reserve space for the resize handle

// Bottom resize handle — horizontal bar on the TOP edge, drag up to expand.
// Inherits base styles from .auto-hide-docked-resize-handle; overrides for
// horizontal orientation.
.auto-hide-docked-resize-handle-bottom
  top: 0
  left: 0
  right: 0
  bottom: auto
  height: 4px
  width: auto
  cursor: ns-resize

// ---------------------------------------------------------------------------
// Bottom auto-hide strip — the sole content of the redesigned #status-base.
// The bar is 2rem tall with 0.25em padding-top/bottom (matching side-strip
// padding-left/right) for curve visibility and consistent breathing room.
// Tabs fill the inner 1.5em height via align-items: stretch.
// ---------------------------------------------------------------------------

#auto-hide-bottom-strip
  display: flex
  flex-direction: row
  align-items: stretch
  flex: 1          // fill the full width of #status-base
  overflow: visible
  position: relative
  z-index: 100
  // Left/right padding matches #ROOT's padding-left/right (0.25em) so the tabs
  // are inset by the same amount as the GL content area on both sides.
  padding-left: 0.25em
  padding-right: 0.25em

// ---------------------------------------------------------------------------
// Bottom strip tab overrides — use the same .auto-hide-strip-tab classes
// as the side strips but re-orient for horizontal bottom layout.
// Open end faces UP (toward GL content / docked panel above).
// ---------------------------------------------------------------------------

#auto-hide-bottom-strip .auto-hide-strip-tab
  // Horizontal layout: tabs stack left-to-right.
  flex-direction: row
  align-items: center
  // Horizontal padding instead of vertical; match the 0.38em breathing room
  // on each side that the side strip uses as padding-left/right.
  padding: 0 0.5em
  margin-bottom: 0
  margin-right: 0.24em
  // Tab height is the full status-bar height — no explicit height needed
  // since the parent is align-items: stretch.
  // All corners 0.36em — matches the side-strip tab border-radius exactly.
  border-radius: 0.36em
  overflow: visible  // allow curve pseudo-elements to bleed outside the tab

  &.active
    color: colors-ui-text-primary-label
    border-radius: 0.36em
    // Shadow bridges the gap between the strip top edge and the docked panel.
    box-shadow: 0em -0.48em 0em 0em colors-ui-surface-panel
    overflow: visible
    z-index: 1

    // LEFT curve — to the left of the active tab.
    &::before
      content: " "
      pointer-events: none
      position: absolute
      display: block
      height: 80%
      width: 1.625em
      top: 0em
      left: -1.625em
      z-index: 1
      border-radius: 0 0.625em 0 0
      opacity: 1
      box-shadow: 0.625em -0.34em 0 -0.25em colors-ui-surface-panel
      transform: translate(0em, -0.25625em)

    // RIGHT curve — to the right of the active tab.
    &::after
      content: " "
      pointer-events: none
      position: absolute
      display: block
      height: 80%
      width: 1.625em
      top: 0em
      right: -1.625em
      z-index: 1
      border-radius: 0.625em 0 0 0
      opacity: 1
      box-shadow: -0.625em -0.34em 0 -0.25em colors-ui-surface-panel
      transform: translate(0em, -0.25625em)

// Label: no writing-mode rotation for horizontal tabs.
// align-self: stretch + internal display: flex + align-items: center ensure
// the label fills the full tab height and the text is truly centered, rather
// than relying on the parent's align-items: center to center the line box
// (which shifts capital letters slightly high due to descender space in the
// line box not being used by all-caps text).
#auto-hide-bottom-strip .auto-hide-strip-tab-label
  writing-mode: horizontal-tb
  text-orientation: mixed
  transform: none
  padding-left: 0
  padding-right: 0.38em
  max-height: none
  align-self: stretch  // fill full tab height instead of centering the line box
  display: flex        // flex container so text node becomes a flex item
  align-items: center  // vertically center the text within the stretched label
  line-height: 1       // collapse descender space so the line box ≈ cap height;
                       // without this, line-height ~1.2 leaves unused space below
                       // caps that shifts their visual center above the line box center

// Buttons sit inline (to the right of the label) instead of above it.
#auto-hide-bottom-strip .auto-hide-strip-tab-buttons
  flex-direction: row
  margin-bottom: 0
  margin-left: 0.2em
  gap: 0.2em

// ---------------------------------------------------------------------------
// Strip tabs — individual clickable tabs within a strip.
// Styled to match lm_tabs but rotated vertically for the side strips.
// The tab div itself is NOT rotated so that ::before/::after pseudo-elements
// work in the normal (unrotated) coordinate space — curves appear correctly
// above and below the active tab.  Rotation is delegated to the inner
// .auto-hide-strip-tab-label span only.
// ---------------------------------------------------------------------------

.auto-hide-strip-tab
  font-family: "SpaceGrotesk"
  font-size: inherit
  font-weight: 600
  letter-spacing: -0.14px
  color: colors-ui-text-primary-disabled
  background-color: colors-ui-surface-panel
  border-radius: 0.36em
  cursor: pointer
  // No horizontal padding — the tab is only 2em wide and removing horizontal
  // padding gives the rotated label enough block-size to render without clipping.
  // top/bottom 0.5em matches lm_tab left/right rotated; horizontal padding is
  // handled by the strip container's 0.38em padding on each side.
  padding: 0.5em 0
  // No horizontal margins — the 0.38em breathing room on each side comes from
  // the strip container's padding-left/right (set on .has-tabs).  This means
  // the tab width is set entirely by the container, exactly like lm_tab height
  // is set by the lm_header container — so no active-state property can shift content.
  margin-bottom: 0.24em
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  position: relative
  z-index: 0
  overflow: hidden
  user-select: none
  transition: color 150ms ease, background-color 150ms ease

  // Active state: open end faces the main content area (right side).
  // Curves appear above (::before) and below (::after) the tab, matching
  // the lm_tabs pattern rotated 90 degrees clockwise.
  &.active
    color: colors-ui-text-primary-label
    border-top-left-radius: 0.36em
    border-bottom-left-radius: 0.36em
    border-top-right-radius: 0em
    border-bottom-right-radius: 0em
    // Shadow bridges the 0.25em gap to the strip edge and extends slightly into
    // the overlay area. The overlay (z-index: 101) renders above the strip (100)
    // and covers the overlap with its own panel-color background — seamless join,
    // no GL content exposed since the overlay covers ROOT at that position.
    box-shadow: 0.48em 0em 0em 0em colors-ui-surface-panel
    overflow: visible
    z-index: 1

    // TOP curve — above the active tab (same geometry as lm_tabs ::before rotated).
    &::before
      content: " "
      pointer-events: none
      position: absolute
      display: block
      width: 80%
      height: 1.625em
      right: 0em
      top: -1.625em
      z-index: 1
      border-radius: 0 0 0.625em 0
      opacity: 1
      box-shadow: 0.34em 0.625em 0 -0.25em colors-ui-surface-panel
      transform: translate(0.25625em, 0em)

    // BOTTOM curve — below the active tab (same geometry as lm_tabs ::after rotated).
    &::after
      content: " "
      pointer-events: none
      position: absolute
      display: block
      width: 80%
      height: 1.625em
      right: 0em
      bottom: -1.625em
      z-index: 1
      border-radius: 0 0.625em 0 0
      opacity: 1
      box-shadow: 0.34em -0.625em 0 -0.25em colors-ui-surface-panel
      transform: translate(0.25625em, 0em)

// -------------------------------------------------------------------------
// Right-strip overrides: curves mirror to the LEFT side of the tab.
// The open end of the right-strip active tab faces LEFT (toward the overlay).
// -------------------------------------------------------------------------

#auto-hide-strip-right .auto-hide-strip-tab.active
  border-top-left-radius: 0em
  border-bottom-left-radius: 0em
  border-top-right-radius: 0.36em
  border-bottom-right-radius: 0.36em
  // Shadow bridges the 0.25em gap to the strip left edge; overlay (z-index: 101)
  // renders above and covers the slight overlap with its panel-color background.
  box-shadow: -0.48em 0em 0em 0em colors-ui-surface-panel

  &::before  // TOP curve — anchored to LEFT side of tab
    left: 0em
    right: auto
    border-radius: 0 0 0 0.625em  // BL rounded
    box-shadow: -0.34em 0.625em 0 -0.25em colors-ui-surface-panel
    transform: translate(-0.25625em, 0em)

  &::after  // BOTTOM curve — anchored to LEFT side of tab
    left: 0em
    right: auto
    border-radius: 0.625em 0 0 0  // TL rounded
    box-shadow: -0.34em -0.625em 0 -0.25em colors-ui-surface-panel
    transform: translate(-0.25625em, 0em)

// First active tab has no top curve (nothing above it to connect to).
#auto-hide-strip-left .auto-hide-strip-tab.active:first-child::before,
#auto-hide-strip-right .auto-hide-strip-tab.active:first-child::before
  display: none

// Bottom strip: first active tab has no LEFT curve (nothing to its left).
#auto-hide-bottom-strip .auto-hide-strip-tab.active:first-child::before
  display: none

// ---------------------------------------------------------------------------
// Tab label span — carries the text rotation so the tab div stays un-rotated.
// ---------------------------------------------------------------------------

.auto-hide-strip-tab-label
  display: block
  // No explicit width — the label takes its natural intrinsic width
  // (≈ font-size for vertical text) and align-items: center on the parent
  // tab centers it horizontally, matching how lm_tab centers content.
  // padding-left/right add 0.38em breathing room between the tab edge and
  // the text characters; they expand the label's natural width symmetrically.
  padding-left: 0.38em
  padding-right: 0.38em
  white-space: nowrap

// Left strip: text reads bottom-to-top.
#auto-hide-strip-left .auto-hide-strip-tab-label
  writing-mode: vertical-lr
  text-orientation: mixed
  transform: rotate(180deg)

// Right strip: text reads top-to-bottom.
#auto-hide-strip-right .auto-hide-strip-tab-label
  writing-mode: vertical-rl
  text-orientation: mixed

// ---------------------------------------------------------------------------
// Tab button group — close and unpin, always visible at the top of each tab.
// Both buttons use stopPropagation so clicking on an inactive tab doesn't
// also activate the panel.
// ---------------------------------------------------------------------------

.auto-hide-strip-tab-buttons
  display: flex
  flex-direction: column
  align-items: center
  gap: 0.3em  // matches lm_pin_tab margin-right spacing between lm_tab buttons
  margin-bottom: 0.5em  // space between unpin button and text label below

// Shared base — icon-only buttons, same appearance as lm_tab buttons.
.auto-hide-strip-tab-btn
  display: block
  background-repeat: no-repeat
  background-position: center
  cursor: pointer
  border: none
  padding: 0
  background-color: transparent
  user-select: none
  border-radius: 0.375em
  transition: background-color 150ms ease

  // Hover matches .lm_controls > *:hover — subtle filled rounded rect.
  &:hover
    background-color: colors-ui-surface-primary-default-hover

// Close button — same icon and size as .lm_close_tab.
.auto-hide-strip-tab-close
  background-image: LAYOUT_TAB_CLOSE_ICON_PATH
  background-size: 0.6em 0.6em
  width: 0.6em
  height: 0.6em

// Unpin button — matches .lm_header .lm_tab .lm_pin_tab exactly:
// dimmed at 0.7 opacity by default, fully opaque on hover, no background fill.
.auto-hide-strip-tab-unpin
  background-image: url('../../public/resources/shared/sidebar_unpin.svg')
  background-size: 0.85em 0.85em
  width: 0.85em
  height: 0.85em
  opacity: 0.7

  &:hover
    opacity: 1
    background-color: transparent  // override .auto-hide-strip-tab-btn:hover

// Bottom tabs in the status bar use ct-button-sm-secondary.
// Override only the layout properties that differ from button defaults.
.auto-hide-bottom-tabs .ct-button-sm-secondary
  flex: 0 1 auto !important
  min-width: 0
  max-width: 14em
  align-self: center
  font-size: 0.6em
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

// ---------------------------------------------------------------------------
// Backdrop — invisible click-to-dismiss layer behind the slide-in panel.
// No background color: the overlay appears without dimming any content.
// z-index: 98 — below the strips (100) so the backdrop never intercepts
// mouseenter/mouseleave on strip tabs (prevents hover-preview flicker).
// ---------------------------------------------------------------------------

#auto-hide-backdrop
  display: none
  position: fixed
  top: 0
  left: 0
  right: 0
  bottom: 0
  background-color: transparent
  z-index: 98

#auto-hide-overlay.visible ~ #auto-hide-backdrop
  display: block

// ---------------------------------------------------------------------------
// Overlay — the slide-in panel that appears when a strip tab is clicked.
// Flush with the window edge, no border-radius, no margin/padding gap.
// ---------------------------------------------------------------------------

#auto-hide-overlay
  position: fixed
  // z-index: 101 — above the backdrop (98) and the strips (100).
  z-index: 101
  // Use surface-panel to match the active strip tab, so the tab's box-shadow
  // connection blends seamlessly into the overlay.
  background-color: colors-ui-surface-panel
  border: none
  border-radius: 0
  box-shadow: none
  margin: 0
  padding: 0
  display: none
  flex-direction: column
  overflow: hidden
  transition: transform 200ms ease

  &.visible
    display: flex

// Edge-specific positioning: each overlay is flush with its edge and
// spans the full available dimension along that edge.

// Left overlay: flush with the strip's right edge (2em from screen left).
// The strip (z-index 100) sits above the overlay so the active-tab curves
// are always visible against the strip background.
// No border — the absolutely-positioned resize handle (4px, same background
// color as GL splitters) serves as the visual separator, identical to the
// docked panel divider.
#auto-hide-overlay.auto-hide-overlay-left
  top: 2.27em  // matches #root-container top: 2.27em (the caption bar height)
  left: 2em
  // Bottom tab strip is 2rem tall. Stop above it so the overlay doesn't overlap.
  bottom: 2rem
  width: 360px

// Right overlay: mirrored.
#auto-hide-overlay.auto-hide-overlay-right
  top: 2.27em  // matches #root-container top: 2.27em (the caption bar height)
  right: 2em
  bottom: 2rem  // stop above the bottom tab strip (2rem)
  width: 360px

// Bottom overlay: sits above the tab strip, inset to match #ROOT left/right padding.
#auto-hide-overlay.auto-hide-overlay-bottom
  left: 0.25em   // matches #ROOT padding-left so content aligns with GL content
  right: 0.25em  // matches #ROOT padding-right
  bottom: 2rem  // stop above the bottom tab strip
  height: 280px

// ---------------------------------------------------------------------------
// Overlay resize handle — sits on the inner edge of the overlay (the edge
// closest to the GL content).  Drag to resize; size is stored per-panel.
// Styled identically to the docked-panel resize handles.
// ---------------------------------------------------------------------------

.auto-hide-overlay-resize-handle
  position: absolute
  z-index: 200  // above overlay GL content
  background: colors-ui-surface-primary-default
  opacity: unset
  transition: background 150ms ease

  &:hover,
  &.resizing
    background: colors-ui-border-interactive-default

// Left overlay: drag the RIGHT edge to widen.
.auto-hide-overlay-left .auto-hide-overlay-resize-handle
  right: 0
  top: 0
  bottom: 0
  width: 4px
  cursor: col-resize

// Right overlay: drag the LEFT edge to widen.
.auto-hide-overlay-right .auto-hide-overlay-resize-handle
  left: 0
  top: 0
  bottom: 0
  width: 4px
  cursor: col-resize

// Bottom overlay: drag the TOP edge upward to increase height.
.auto-hide-overlay-bottom .auto-hide-overlay-resize-handle
  top: 0
  left: 0
  right: 0
  height: 4px
  cursor: ns-resize

// Push the overlay body away from the position:absolute resize handle so
// the handle does not overdraw the edge of the content.
// Mirrors the docked panels' #auto-hide-docked-{left,right}-content
// padding-{right,left}: 4px and #auto-hide-docked-bottom-content padding-top: 4px.
.auto-hide-overlay-right #auto-hide-overlay-body
  padding-left: 4px

.auto-hide-overlay-left #auto-hide-overlay-body
  padding-right: 4px

.auto-hide-overlay-bottom #auto-hide-overlay-body
  padding-top: 4px

// ---------------------------------------------------------------------------
// Overlay header — hidden: the active strip tab acts as the panel header.
// The close and unpin buttons are embedded in the strip tab itself.
// ---------------------------------------------------------------------------

#auto-hide-overlay-header
  display: none !important

// ---------------------------------------------------------------------------
// Overlay content area
// ---------------------------------------------------------------------------

#auto-hide-overlay-content
  flex: 1
  overflow: auto
  padding: 0
  position: relative  // Anchor for the floating pin button

// ---------------------------------------------------------------------------
// Collapsed-mode overlay: hide the full header row and show a small
// floating pin/unpin button in the upper-right corner instead.
// The panel title is already visible in the side-edge tab bar.
// ---------------------------------------------------------------------------

#auto-hide-overlay.collapsed-overlay #auto-hide-overlay-header
  display: none

// Floating pin button — appears only in collapsed-overlay mode.
.overlay-floating-pin
  position: absolute
  top: 4px
  right: 4px
  z-index: 5
  cursor: pointer
  font-size: 14px
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  border-radius: 3px
  color: HEADER_PANEL_COLOR
  background-color: rgba(40, 40, 40, 0.7)
  border: 1px solid PRIMARY_BASE
  transition: background-color 150ms ease
  opacity: 0.6

  &:hover
    background-color: ACTIVE_ROW
    opacity: 1.0

// ---------------------------------------------------------------------------
// Collapsed-mode icon zone — rendered in the status bar.
// Uses the same accent color as the collapsed strip line.
// ---------------------------------------------------------------------------

.collapsed-icon-zone
  display: none

// The icon zone sits at the very left of the status bar, flush with the
// left edge so it visually connects with the collapsed side strip above.
// No margin-left, no border-radius on the left side.
.collapsed-icon-zone.has-icons
  display: flex
  flex-direction: row
  align-items: center
  gap: 2px
  margin: 0
  padding: 0 6px
  background-color: #3a5070  // Same accent as collapsed strip
  border-radius: 0 3px 3px 0  // Rounded only on the right
  height: 100%  // Full status bar height for seamless connection
  align-self: stretch

.collapsed-icon
  font-size: 14px
  cursor: pointer
  padding: 1px 3px
  border-radius: 2px
  background-color: transparent
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: #4a6080

// ---------------------------------------------------------------------------
// Side-edge tabs — VS Studio style, inside the overlay.
// Rendered as a vertical strip between the screen edge and overlay content.
// ---------------------------------------------------------------------------

.overlay-side-tabs
  display: flex
  flex-direction: column
  flex-shrink: 0
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  padding-top: 4px
  gap: 2px
  overflow: hidden

  &.hidden
    display: none

// Left-edge tabs: between screen left edge and overlay content.
// Background matches the overlay, border only on the content side.
.overlay-side-tabs.side-tabs-left
  width: 28px
  min-width: 28px
  border-right: 1px solid PRIMARY_BASE
  order: -1  // Place before overlay content in flex row
  background-color: SECONDARY_BASE  // Match overlay background

// Right-edge tabs: between overlay content and screen right edge.
.overlay-side-tabs.side-tabs-right
  width: 28px
  min-width: 28px
  border-left: 1px solid PRIMARY_BASE
  order: 1  // Place after overlay content in flex row
  background-color: SECONDARY_BASE

.overlay-side-tab
  writing-mode: vertical-lr
  text-orientation: mixed
  transform: rotate(180deg)
  font-family: "SpaceMono"
  font-size: 12px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  background-color: HEADER_PANEL_INACTIVE_COLOR
  cursor: pointer
  padding: 3px 6px
  margin: 2px
  max-height: 120px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

  &.active
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

// Right-edge tabs read top-to-bottom (no rotation).
.side-tabs-right .overlay-side-tab
  writing-mode: vertical-rl
  transform: none

#auto-hide-strip-left.drag-over,
#auto-hide-strip-right.drag-over
  width: 2em !important
  max-width: 2em !important
  background-color: rgba(65, 105, 225, 0.4) !important
  box-shadow: inset 0 0 10px rgba(65, 105, 225, 0.6)

#auto-hide-bottom-strip.drag-over
  background-color: rgba(65, 105, 225, 0.4) !important
  box-shadow: inset 0 0 10px rgba(65, 105, 225, 0.6)
