// Auto-hide strip styles.
//
// Three strips (left, right, bottom) sit at the edges of the session
// container and hold tabs for panels that have been auto-hidden.  When no
// panels are present the strip has zero dimensions (display: none is set
// inline by the Nim code).
//
// Theme variables (BACKGROUND_COLOR, HEADER_PANEL_BACKGROUND_COLOR, etc.)
// are defined in the theme stylus files and available here because this
// file is imported from codetracer.styl after the theme is loaded.

// ---------------------------------------------------------------------------
// Shared strip base
// ---------------------------------------------------------------------------

.auto-hide-strip
  position: absolute
  z-index: 5
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  overflow: hidden
  // Transition for smooth show/hide if we later animate dimensions.
  transition: width 150ms ease, height 150ms ease

// ---------------------------------------------------------------------------
// Edge-specific positioning
// ---------------------------------------------------------------------------

.auto-hide-strip-left
  top: 0
  left: 0
  bottom: 0
  width: 28px
  display: flex
  flex-direction: column
  align-items: center
  border-right: 1px solid PRIMARY_BASE

.auto-hide-strip-right
  top: 0
  right: 0
  bottom: 0
  width: 28px
  display: flex
  flex-direction: column
  align-items: center
  border-left: 1px solid PRIMARY_BASE

.auto-hide-strip-bottom
  left: 0
  right: 0
  bottom: 0
  height: 28px
  display: flex
  flex-direction: row
  align-items: center
  border-top: 1px solid PRIMARY_BASE

// ---------------------------------------------------------------------------
// Adaptive strip sizing (M12: Fitts' Law edge bounding)
// ---------------------------------------------------------------------------
// When the window edge coincides with the screen boundary the mouse cursor
// naturally stops at the edge, so the activation strip can be very thin
// (3px).  When there is space beyond the edge (floating window or adjacent
// monitor), we keep the default 28px width so the user can hit the target
// comfortably.  The Nim code toggles the `auto-hide-strip-bounded` class
// per-edge based on runtime window/screen geometry.

.auto-hide-strip-bounded
  &.auto-hide-strip-left,
  &.auto-hide-strip-right
    width: 3px
  &.auto-hide-strip-bottom
    height: 3px

// ---------------------------------------------------------------------------
// Individual tab
// ---------------------------------------------------------------------------

.auto-hide-tab
  display: flex
  align-items: center
  justify-content: center
  cursor: pointer
  user-select: none
  color: HEADER_PANEL_COLOR
  font-family: "SpaceGrotesk"
  font-size: 12px
  font-weight: 500
  transition: background-color 150ms ease

  &:hover
    background-color: ACTIVE_ROW

  &.auto-hide-tab-active
    background-color: BACKGROUND_COLOR
    color: PRIMARY_TEXT_COLOR

// Tabs in vertical strips (left / right) are rotated and stacked vertically.
.auto-hide-strip-left .auto-hide-tab,
.auto-hide-strip-right .auto-hide-tab
  writing-mode: vertical-lr
  padding: 8px 4px
  width: 100%
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

// Left strip text reads bottom-to-top for a natural reading direction.
.auto-hide-strip-left .auto-hide-tab
  transform: rotate(180deg)

// Tabs in the horizontal bottom strip flow left to right.
.auto-hide-strip-bottom .auto-hide-tab
  padding: 4px 10px
  height: 100%
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

// ---------------------------------------------------------------------------
// Icon and title inside a tab
// ---------------------------------------------------------------------------

.auto-hide-tab-icon
  font-size: 14px
  flex-shrink: 0

// Vertical strips: icon sits above title.
.auto-hide-strip-left .auto-hide-tab-icon,
.auto-hide-strip-right .auto-hide-tab-icon
  margin-bottom: 4px

// Horizontal strip: icon sits to the left of title.
.auto-hide-strip-bottom .auto-hide-tab-icon
  margin-right: 6px

.auto-hide-tab-title
  overflow: hidden
  text-overflow: ellipsis

// Vertical strips: constrain title length so it does not overflow.
.auto-hide-strip-left .auto-hide-tab-title,
.auto-hide-strip-right .auto-hide-tab-title
  max-height: 100px

// ---------------------------------------------------------------------------
// Overlay backdrop
// ---------------------------------------------------------------------------

.auto-hide-backdrop
  position: absolute
  top: 0
  left: 0
  right: 0
  bottom: 0
  background: rgba(0, 0, 0, 0.3)
  z-index: 6
  display: none

// ---------------------------------------------------------------------------
// Overlay panel (slide-in container)
// ---------------------------------------------------------------------------

.auto-hide-overlay
  position: absolute
  z-index: 7
  background: BACKGROUND_COLOR
  border: 1px solid LAYOUT_SPLITTER_COLOR
  display: none
  overflow: hidden
  transition: transform 0.2s ease-out

  // Overlay from left edge — slides in from behind the left strip.
  // The inset uses a CSS variable so it tracks the adaptive strip width
  // set by the M12 edge-bounding logic in auto_hide.nim.
  &.auto-hide-overlay-left
    top: 0
    bottom: 0
    left: var(--auto-hide-strip-left, 28px)
    transform: translateX(-100%)
    &.auto-hide-overlay-visible
      transform: translateX(0)

  // Overlay from right edge — slides in from behind the right strip.
  &.auto-hide-overlay-right
    top: 0
    bottom: 0
    right: var(--auto-hide-strip-right, 28px)
    transform: translateX(100%)
    &.auto-hide-overlay-visible
      transform: translateX(0)

  // Overlay from bottom edge — slides up from behind the bottom strip.
  &.auto-hide-overlay-bottom
    left: 0
    right: 0
    bottom: var(--auto-hide-strip-bottom, 28px)
    transform: translateY(100%)
    &.auto-hide-overlay-visible
      transform: translateY(0)

// ---------------------------------------------------------------------------
// Overlay header (title, pin, close)
// ---------------------------------------------------------------------------

.auto-hide-overlay-header
  display: flex
  align-items: center
  padding: 4px 8px
  background: HEADER_PANEL_BACKGROUND_COLOR
  border-bottom: 1px solid LAYOUT_SPLITTER_COLOR
  height: 28px
  user-select: none

.auto-hide-overlay-title
  flex: 1
  color: PRIMARY_TEXT_COLOR
  font-family: "SpaceGrotesk"
  font-size: 12px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.auto-hide-overlay-btn
  cursor: pointer
  color: HEADER_PANEL_COLOR
  padding: 2px 6px
  font-size: 12px
  &:hover
    color: PRIMARY_TEXT_COLOR

// ---------------------------------------------------------------------------
// Overlay content area
// ---------------------------------------------------------------------------

.auto-hide-overlay-content
  position: absolute
  top: 28px
  left: 0
  right: 0
  bottom: 0
  overflow: auto

// ---------------------------------------------------------------------------
// Drag-to-edge indicators (M8)
// ---------------------------------------------------------------------------
// Shown during GL drag operations when the cursor nears a container edge.
// These are pointer-events:none overlays that hint where the panel will
// land if the user drops it.

.auto-hide-indicator
  position: absolute
  z-index: 8
  background: rgba(86, 86, 86, 0.15)
  border: 2px dashed PRIMARY_BASE
  display: none
  pointer-events: none

.auto-hide-indicator-left
  @extend .auto-hide-indicator
  top: 0
  bottom: 0
  left: 0
  width: 50px

.auto-hide-indicator-right
  @extend .auto-hide-indicator
  top: 0
  bottom: 0
  right: 0
  width: 50px

.auto-hide-indicator-bottom
  @extend .auto-hide-indicator
  left: 0
  right: 0
  bottom: 0
  height: 50px

// ---------------------------------------------------------------------------
// Status bar toggle icons (M10)
// ---------------------------------------------------------------------------
// Small clickable icons rendered inside the Karax status bar for each
// auto-hidden panel.  Clicking toggles the panel overlay, same as the
// strip tabs.

.auto-hide-status-icons
  display: inline-flex
  align-items: center
  gap: 2px
  margin-left: 8px
  margin-right: 8px

.auto-hide-status-icon
  cursor: pointer
  padding: 2px 6px
  border-radius: 3px
  font-size: 11px
  color: HEADER_PANEL_COLOR
  &:hover
    color: PRIMARY_TEXT_COLOR
    background: rgba(255, 255, 255, 0.1)
  &.auto-hide-status-icon-active
    color: PRIMARY_TEXT_COLOR
    background: PRIMARY_BASE
