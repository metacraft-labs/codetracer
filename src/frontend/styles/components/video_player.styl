// Video Player pane — Visual Replay GUI.
// Spec: codetracer-specs/GUI/Debugging-Features/Visual-Replay.md

.video-player-component
  display: flex
  flex-direction: column
  height: 100%
  width: 100%
  min-height: 0
  box-sizing: border-box
  overflow: hidden
  color: TEXT_CONTENT_COLOR
  background: BACKGROUND_COLOR
  font-family: "FiraCode"
  font-size: 13px
  line-height: 20px

  &.picker-active
    cursor: crosshair

  // --- Stage (frame canvas + overlays) ----------------------------------
  .video-player-stage
    position: relative
    flex: 1 1 auto
    min-height: 0
    overflow: hidden
    display: flex
    align-items: center
    justify-content: center
    background: #0a0a0a

  .video-player-image
    max-width: 100%
    max-height: 100%
    image-rendering: pixelated
    user-select: none
    pointer-events: none

  .video-player-empty,
  .video-player-loading,
  .video-player-error
    position: absolute
    top: 50%
    left: 50%
    transform: translate(-50%, -50%)
    color: #cccccc
    font-size: 14px
    text-align: center
    pointer-events: none

  .video-player-error
    color: #ff6b6b

  .video-player-canvas-overlay
    position: absolute
    top: 0
    left: 0
    right: 0
    bottom: 0
    pointer-events: none

    &.picker
      box-shadow: inset 0 0 0 2px rgba(80, 160, 255, 0.85)

  // --- Magnifier loupe --------------------------------------------------
  .video-player-loupe
    position: absolute
    width: 120px
    pointer-events: none
    z-index: 10
    transform-origin: top left

  .video-player-loupe-canvas
    width: 120px
    height: 120px
    border-radius: 50%
    border: 2px solid rgba(255, 255, 255, 0.85)
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.6), 0 8px 16px rgba(0, 0, 0, 0.5)
    background: #111
    image-rendering: pixelated

  .video-player-loupe-readout
    margin-top: 4px
    padding: 2px 6px
    background: rgba(0, 0, 0, 0.78)
    color: #eaeaea
    font-size: 11px
    line-height: 14px
    border-radius: 3px
    white-space: nowrap
    text-align: center

  // --- Transport bar ----------------------------------------------------
  .video-player-transport
    flex: 0 0 auto
    display: flex
    align-items: center
    gap: 6px
    padding: 6px 10px
    border-top: 1px solid ACTIVE_MENU_BACKGROUND
    background: HEADER_PANEL_BACKGROUND_COLOR

  .video-player-button
    display: inline-flex
    align-items: center
    justify-content: center
    min-width: 28px
    height: 28px
    padding: 0 6px
    border: 1px solid transparent
    border-radius: 4px
    background: transparent
    color: TEXT_CONTENT_COLOR
    cursor: pointer
    font-size: 14px
    line-height: 1
    user-select: none

    &:hover
      background: ACTIVE_MENU_BACKGROUND

    &:active,
    &.pressed
      background: ACTIVE_MENU_BACKGROUND
      border-color: rgba(80, 160, 255, 0.85)
      color: #ffffff

  .video-player-divider
    width: 1px
    height: 18px
    background: ACTIVE_MENU_BACKGROUND
    margin: 0 4px

  .video-player-rate-badge
    margin-left: auto
    padding: 2px 8px
    border-radius: 3px
    background: rgba(80, 160, 255, 0.18)
    color: #cfe7ff
    font-size: 11px
    font-weight: 600
    text-transform: uppercase
    white-space: nowrap

  .video-player-buffering
    margin-left: 6px
    color: #ffcc55
    font-size: 14px
    line-height: 1

  // --- Scrub slider -----------------------------------------------------
  .video-player-scrubber
    flex: 0 0 auto
    padding: 4px 10px 8px
    background: HEADER_PANEL_BACKGROUND_COLOR
    border-top: 1px solid ACTIVE_MENU_BACKGROUND

  .video-player-scrub-range
    width: 100%
    accent-color: rgba(80, 160, 255, 0.85)

  .video-player-scrub-labels
    display: flex
    align-items: center
    justify-content: space-between
    gap: 12px
    margin-top: 2px
    color: VALUE_TYPE_COLOR
    font-size: 11px
    line-height: 14px

  .video-player-selected-pixel
    color: TEXT_CONTENT_COLOR
