.pixel-history-component
  display: flex
  flex-direction: column
  height: 100%
  width: 100%
  min-height: 0
  box-sizing: border-box
  overflow: hidden
  color: colors-ui-text-primary-body
  background: colors-ui-surface-base-panel
  font-family: "FiraCode"
  font-size: 13px
  line-height: 20px

  .pixel-history-header
    display: flex
    align-items: center
    justify-content: space-between
    gap: 10px
    padding: 7px 10px
    flex: 0 0 auto
    border-bottom: 1px solid colors-ui-surface-input-default
    background: colors-ui-surface-primary-tertiary

  .pixel-history-title
    font-weight: 600

  .pixel-history-pixel
    color: colors-ui-text-primary-body
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

  .pixel-history-loading,
  .pixel-history-error,
  .pixel-history-empty
    padding: 10px
    color: colors-ui-text-primary-body

    &[display="none"]
      display: none

  .pixel-history-error
    color: colors-ui-text-error-primary

  .pixel-history-list
    min-height: 0
    overflow: auto
    flex: 1 1 auto

  .pixel-history-entry
    display: grid
    grid-template-columns: 1fr
    gap: 6px
    width: 100%
    min-height: 84px
    padding: 8px 10px
    border: 0
    border-bottom: 1px solid colors-ui-border-secondary
    background: transparent
    color: colors-ui-text-primary-body
    font: inherit
    text-align: left
    cursor: pointer

    &:hover,
    &.selected
      background: colors-ui-surface-primary-secondary-hover

  .pixel-history-entry-main
    display: grid
    grid-template-columns: auto auto 1fr
    gap: 8px
    align-items: center
    min-width: 0

  .pixel-history-draw,
  .pixel-history-geid
    color: colors-ui-text-primary-body

  .pixel-history-pass
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    color: colors-ui-text-primary-body

  .pixel-history-colors
    display: grid
    grid-template-columns: repeat(3, minmax(0, 1fr))
    gap: 6px
    min-width: 0

  .pixel-history-color
    display: flex
    align-items: center
    gap: 5px
    min-width: 0

  .pixel-history-swatch
    flex: 0 0 auto
    width: 14px
    height: 14px
    border: 1px solid colors-ui-border-secondary
    border-radius: 3px

  .pixel-history-color-label,
  .pixel-history-tests
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    color: colors-ui-text-primary-body
    font-size: 12px
