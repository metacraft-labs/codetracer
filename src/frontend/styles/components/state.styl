.state-component
  font-family: "SpaceMono" !important

.events-bottom
  height: 12.5em
  float: left

.code-state-line.no-code
  display: none
  margin-bottom: 0


.value-expanded-type
  padding-right: 0.625em
  white-space: nowrap

// TODO:
.value-expanded-name
  // min-width: 3.75em
  //cursor: pointer
  font-size: inherit
  // line-height: 1.5em
  padding-left: 0.5em
  color: TEXT_CONTENT_COLOR

.value-expand-button
  display: inline-block
  min-width: 0.9375em
  max-width: 0.9375em
  // ?
  float: left

  i
    font-size: inherit

.value-non-expanded
  color: orange

.value-error
  color: CALLTRACE_END_OF_PROGRAM_ERROR

.value-non-expanded, .value-error
  position: absolute
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  width: 95%
  background: BACKGROUND_COLOR

.value-watch
  font-style: italic

.value-selected
  opacity: 0.5

.value-name
  color: VALUE_NAME_COLOR
  white-space: nowrap

.value-type
  margin-left: 0.5em
  color: VALUE_TYPE_COLOR
  white-space: nowrap

.value-annotation
  margin-left: 0.3125em
  color: VALUE_TYPE_COLOR
  opacity: 0.5
  white-space: nowrap

.value-view
  .value-error
    margin-left: 1.0625em !important
    position: inherit

.value-name-container
  display: flex
  align-items: center

  .caret-collapse
    display: block
    background-image: SHARED_OPEN_FA_ICON
    background-position: center
    background-repeat: no-repeat
    width: 0.5em
    height: 0.5em

  .caret-expand
    display: block
    background-image: SHARED_CLOSE_FA_ICON
    background-position: center
    background-repeat: no-repeat
    width: 0.5em
    height: 0.5em

.value-line-view-text
  display: flex
  white-space: nowrap
  text-overflow: visible
//padding-right: 1.5625em

.value-expanded-view-text
  display: flex
  flex-direction: column
  white-space: nowrap
  text-overflow: visible
//padding-right: 1.5625em

.value-expanded-name-text-content
  width: 100%
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis

.value-expanded-view
  //flex-basis: 68%
  color: TEXT_CONTENT_COLOR
  position: relative
  margin-left: 0.625em
  background: BACKGROUND_COLOR

