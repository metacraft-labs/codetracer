.step-list
  background-color: BACKGROUND_COLOR
  color: TEXT_CONTENT_COLOR
  font-family: "FiraCode", monospace
  font-size: 13px
  line-height: 1.5em
  overflow: auto
  height: 100%

  .step-list-lines-box,
  .step-lines
    min-height: 100%

  .step-line-pre
    display: inline
    margin: 0
    font: inherit
    white-space: pre
    background-color: transparent

  .active-step-line-pre
    background-color: transparent
    color: TEXT_CONTENT_COLOR !important

  .inactive-step-line-pre
    background-color: transparent
    color: TEXT_CONTENT_COLOR

  .step-line
    display: grid
    grid-template-columns: 3em 13em minmax(18em, 1fr) minmax(14em, 24em)
    align-items: center
    column-gap: 0.75em
    margin-left: 0
    min-height: 1.625em
    width: 100%
    box-sizing: border-box
    border-top: 0.0625em solid EVENT_LOG_ROWS_BORDERS_COLOR
    padding: 0 0.75em
    cursor: pointer

    &:hover
      background-color: ACTIVE_ROW

  .active-step-line
    background-color: ACTIVE_ROW
    color: TEXT_CONTENT_COLOR !important

  .step-line-column
    display: block
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

  .step-line-delta
    width: auto
    color: VALUE_TYPE_COLOR

  .step-line-location
    width: auto
    color: #9cdcfe

  .step-line-source-code
    width: auto

  .step-line-call
    grid-template-columns: minmax(0, 1fr) minmax(14em, 24em)
    background-color: rgba(210, 153, 34, 0.12)
    color: TEXT_CONTENT_COLOR

  .step-line-return
    grid-template-columns: minmax(0, 1fr) minmax(14em, 24em)
    background-color: rgba(251, 146, 60, 0.16)
    color: TEXT_CONTENT_COLOR

  .step-line-description
    display: block
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    width: auto

  .step-line-args,.step-line-return-value
    display: block
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    width: auto
    color: VALUE_TYPE_COLOR

  .step-line-flow-values
    width: auto
    background-color: transparent
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

    .step-line-flow-value
      margin-left: 0.625em

      &:first-child
        margin-left: 0

    .step-line-flow-value-repr
      margin-left: 0.3125em
      color: VALUE_RESULT_COLOR
      background-color: transparent

.excerpt-code
  color: TEXT_CONTENT_COLOR

.code-state-line
  font-family: "FiraMono", monospace
  text-overflow: ellipsis
  overflow: hidden
  white-space: nowrap

  &:hover .code-tooltip
    display: block
    transition-delay: TOOLTIP_DELAY_TIMER
    opacity: 1
    visibility: visible


.active-trace2, .active-history, .active-dialog
  display: block
  height: 100%
  width: 100%
  background-color: ACTIVE_COLOR_BG
  color: ACTIVE_COLOR_FG
  overflow-y: scroll

.inactive-trace, .inactive-dialog
  display: none

.active-state
  display: flex
  flex-direction: column

  .select-kind-button-container
    position: absolute
    margin-left: 0.625em

#dialog
  display: flex
  flex-direction: column
  background-color: DIALOG_COLOR_BG
  color: DIALOG_COLOR_FG

.expandable-value
  text-align: center
  font-size: 1.25em

.expandable-child
  width: 100%
  float: left
  font-size: 1.25em
  margin-left: 0.625em

.border-value-0
  border: 0 // 0 COLOR solid
// margin-left: 0.625em

.expanded
  for i in 0..100
    &-{i}
      float: left
      width: 99%
      margin-left: 0.625em * i
      display: inline-flex

.value-expanded-atom
  position: relative
  display: flex
  padding-left: 0.625em
// &.atom-even



.value-expanded-atom-parent
  display: flex
  flex-direction: row
  align-items: center
  width: fit-content

.value-expanded-compound-parent
  display: flex
  flex-direction: column

.value-expanded-compound
  display: flex
  flex-direction: column

.value-expanded
  if IS_EXTENSION
    width: calc(100% - 0.625em)
  else
    width: 100%
  display: flex
  flex-direction: column
  overflow: visible /*hidden*/
  position: relative
  // margin-top: 0.15625em

.value-history-button
  display: block
  width: 0.625em
  font-size: 0.625em
  color: yellow
  float: right
  margin-right: 0.625em
// visibility: hidden

/*.value-history-button:hover */
/*  visibility: visible */

.atom-even
  // background-color: BACKGROUND_COLOR
  color: COLOR

.atom-odd
  // background-color: BACKGROUND_COLOR
  color: COLOR

.chevron
  color: TEXT_CONTENT_COLOR
  cursor: pointer
  position: absolute

  &::before
    border-style: solid
    border-width: 0.1em 0.1em 0 0
    content: ''
    display: inline-block
    height: 0.45em
    left: -0.3125em
    position: absolute
    top: 0.15em
    transform: rotate(135deg)
    vertical-align: top
    width: 0.45em

#chevron-container
  margin-bottom: 0.625em
  margin-left: 0.625em
  margin-right: 0.625em
  position: relative


//   &.bottom:before
//     top: 0
//     transform: rotate(135deg)

