  flex-basis: 75%

.low-level-editor-1
  flex-basis: 50% !important

.low-level
  display: flex
  flex-direction: column
  background-color: colors-ui-surface-base-panel
  color: colors-ui-text-primary-body
  overflow: scroll
  flex-basis: 25%
  height: 100vh
  white-space: pre


