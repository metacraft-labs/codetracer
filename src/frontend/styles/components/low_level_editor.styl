.low-level-full
  flex-basis: 100%

.editor-info
  display: flex
  height: fit-content
  margin-left: 0
  flex-direction: column

  .monaco-scrollable-element
    margin-left: 8px

  .editor-vertical-line
    position: absolute
    width: 3px
    height: calc(100% + 20px)
    top: -8px
    left: 57px
    background-color: colors-ui-border-primary
    z-index:2 !important

    &.splitter
      left 0
      width: 100%
      top: 100% !important
      height: 16px !important
      //z-index: 56 !important

      .editor-splitter-scratch
        position: absolute
        width: 20px
        height: 1px
        background-color: colors-ui-surface-input-default
        z-index: 4
        left: calc(50% - 10px)

      &:hover
        cursor: row-resize

  .editor-textarea
    // flex-basis: 40%
    position: relative
    // height: 40%
    width: 100%
    background-color: colors-ui-surface-input-default
    border-radius: 6px
    // border-right: 3px solid #5a595c

    // .line-numbers
    //   margin-left: 0px !important
    //   padding-right: 8px !important
    //   background-color: colors-ui-surface-input-default
    //   border-right: 3px solid colors-ui-border-primary
    //   text-align: right !important

    .active-line-number
      color: #c6c6c6 !important

    .view-lines
      background-color: colors-ui-surface-input-default

      .view-line
        background-color: colors-ui-surface-input-default

    .margin-view-overlays
      background-color: colors-ui-surface-input-default

  .editor-textarea-empty-header
    // border-left: 3px solid #5a595c
    position: relative
    left:57px
    width: calc(100% - 57px)
    height: 8px
    background-color: colors-ui-surface-input-default
    border-radius: 6px

  .editor-traces
    margin-top: 0.24em
    width: 100%
    // height: 60%
    overflow: visible
    background-color: colors-ui-surface-input-default
    position: relative
    display: flex
    flex-direction: column
    border-radius: 0.325em
    min-height: 0

    .dt-scroll-body::-webkit-scrollbar-thumb
      border-color: colors-ui-surface-input-default

    .editor-trace
      display: flex
      flex-direction: column
      color: TRACE_EXPAND_COLOR

      .editor-codeID
        height: 19px

      .editor-locals
        display: flex
        flex-direction: column

        .editor-local
          display: flex

          .editor-local-name
            flex-basis: 50%

          .editor-local-value
            flex-basis: 50%

  .chart-table
    background-color: colors-ui-surface-input-default
    height: 100%
    display: flex
    flex-direction: column
    flex: 1 1 auto
    min-height: 0
    overflow: hidden

    .data-table
      display: flex
      flex-direction: column
      flex: 1 1 auto
      height: 100%
      min-height: 0
      overflow: hidden

      .dt-container
        flex: 1 1 auto
        min-height: 0

      .dt-scroll
        display: flex
        flex: 1 1 auto
        flex-direction: column
        min-height: 0

      .dt-scroll-body
        flex: 1 1 auto
        min-height: 0

  .monaco-editor .margin
    z-index: 1

.low-level-editor
  height: 100%

.low-level-code
  background-color: colors-ui-surface-base-panel
  color: colors-ui-text-primary-body
  display: flex
  flex-direction: column
  overflow: auto
  font-family: "FiraCode", monospace
  font-size: 13px
  line-height: 20px

.low-level-code-header
  flex: 0 0 auto
  padding: 0.35em 0.5em
  border-bottom: 1px solid colors-ui-surface-primary-tertiary
  opacity: 0.85

.low-level-code-instructions
  min-width: max-content
  padding: 0.25em 0

.low-level-code-instruction
  display: grid
  grid-template-columns: 5em 6em 18em 14em 1fr
  min-height: 1.55em
  line-height: 1.55em
  padding: 0 0.5em
  white-space: nowrap
  border-bottom: 1px solid colors-ui-border-secondary

  &:hover
    background-color: colors-ui-surface-primary-secondary-hover

  &.active-instruction
    background-color: colors-ui-surface-primary-secondary-hover
    color: colors-ui-text-primary-body

.low-level-code-instruction-offset
  opacity: 0.65

.low-level-code-instruction-name
  color: colors-ui-text-primary-body

.low-level-code-instruction-source
  opacity: 0.65
