// VCS (Version Control System) panel styles.
// Matches the CodeTracer dark theme and is designed for a narrow (~200px)
// left-sidebar panel.

.vcs-container
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden
  color: TEXT_CONTENT_COLOR
  font-family: "SpaceGrotesk", sans-serif
  font-size: 13px

// ---------------------------------------------------------------------------
// No-repo placeholder
// ---------------------------------------------------------------------------

.vcs-no-repo
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  height: 100%
  color: #888
  gap: 12px

.vcs-no-repo-icon
  font-size: 32px
  opacity: 0.5

.vcs-no-repo-message
  font-size: 13px
  text-align: center
  padding: 0 16px

// ---------------------------------------------------------------------------
// Branch picker
// ---------------------------------------------------------------------------

.vcs-branch-picker
  position: relative
  flex-shrink: 0
  border-bottom: 1px solid #3c3c3c
  background: #252526

.vcs-branch-current
  display: flex
  align-items: center
  padding: 6px 8px
  cursor: pointer
  gap: 6px
  user-select: none

  &:hover
    background: #3c3c3c

.vcs-branch-icon
  font-size: 14px
  opacity: 0.7

.vcs-branch-name
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-weight: 500

.vcs-branch-arrow
  font-size: 10px
  opacity: 0.6

.vcs-branch-dropdown
  position: absolute
  top: 100%
  left: 0
  right: 0
  z-index: 100
  background: #1e1e1e
  border: 1px solid #3c3c3c
  max-height: 200px
  overflow-y: auto

.vcs-branch-option
  padding: 4px 8px
  cursor: pointer
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

  &:hover
    background: #3c3c3c

.vcs-branch-active-marker
  color: #4ec9b0
  font-weight: bold

// ---------------------------------------------------------------------------
// Section headers
// ---------------------------------------------------------------------------

.vcs-section-header
  padding: 4px 8px
  font-size: 11px
  font-weight: 600
  text-transform: uppercase
  letter-spacing: 0.5px
  color: #888
  background: #252526
  border-bottom: 1px solid #3c3c3c
  flex-shrink: 0
  user-select: none

.vcs-changed-files-commit
  font-family: "FiraMono", "Consolas", monospace
  font-size: 10px
  font-weight: 400
  text-transform: none
  letter-spacing: 0
  color: #666

// ---------------------------------------------------------------------------
// Commit history
// ---------------------------------------------------------------------------

.vcs-commit-history
  flex: 1
  display: flex
  flex-direction: column
  min-height: 0
  border-bottom: 1px solid #3c3c3c

.vcs-commit-list
  flex: 1
  overflow-y: auto
  overflow-x: hidden

.vcs-commit-item
  display: flex
  flex-direction: column
  padding: 4px 8px
  cursor: pointer
  border-bottom: 1px solid #2a2a2a
  gap: 1px

  &:hover
    background: #2a2d2e

.vcs-commit-selected
  background: #094771 !important

.vcs-commit-hash
  font-family: "FiraMono", "Consolas", monospace
  font-size: 11px
  color: #4ec9b0
  flex-shrink: 0

.vcs-commit-message
  font-size: 12px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  color: #ccc

.vcs-commit-time
  font-size: 10px
  color: #666

// ---------------------------------------------------------------------------
// Changed files
// ---------------------------------------------------------------------------

.vcs-changed-files
  flex: 1
  display: flex
  flex-direction: column
  min-height: 0

.vcs-file-list
  flex: 1
  overflow-y: auto
  overflow-x: hidden

.vcs-no-files
  padding: 8px
  color: #666
  font-style: italic
  text-align: center

.vcs-file-item
  display: flex
  align-items: center
  padding: 3px 8px
  cursor: pointer
  gap: 6px

  &:hover
    background: #2a2d2e

.vcs-file-status
  font-family: "FiraMono", "Consolas", monospace
  font-size: 11px
  font-weight: bold
  width: 14px
  text-align: center
  flex-shrink: 0

.vcs-status-added
  color: #4ec9b0

.vcs-status-deleted
  color: #f44747

.vcs-status-modified
  color: #e5c07b

.vcs-status-other
  color: #888

.vcs-file-name
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-size: 12px

.vcs-file-stats
  font-family: "FiraMono", "Consolas", monospace
  font-size: 10px
  flex-shrink: 0
  display: flex
  gap: 4px

.vcs-stat-added
  color: #4ec9b0

.vcs-stat-deleted
  color: #f44747

// ---------------------------------------------------------------------------
// Refresh button
// ---------------------------------------------------------------------------

.vcs-refresh
  flex-shrink: 0
  padding: 4px 8px
  text-align: center
  cursor: pointer
  font-size: 11px
  color: #888
  background: #252526
  border-top: 1px solid #3c3c3c
  user-select: none

  &:hover
    background: #3c3c3c
    color: #ccc

// ---------------------------------------------------------------------------
// Hunk editor: selection, toolbar, and visual indicators
// ---------------------------------------------------------------------------

.hunk-header-selectable
  cursor: pointer
  user-select: none
  transition: background 0.1s ease

  &:hover
    background: #3a3d41

.hunk-selected
  border-left: 3px solid #569cd6
  background: rgba(86, 156, 214, 0.08)

  .deepreview-unified-hunk-header
    background: rgba(86, 156, 214, 0.15)

.hunk-selection-indicator
  display: inline-block
  margin-right: 6px
  color: #569cd6
  font-size: 12px
  font-weight: bold

// Floating toolbar shown when hunks are selected.
.hunk-toolbar
  position: sticky
  top: 0
  z-index: 50
  display: flex
  align-items: center
  justify-content: space-between
  padding: 4px 10px
  background: #1e1e1e
  border: 1px solid #3c3c3c
  border-radius: 4px
  margin: 4px 0 6px 0
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3)
  font-size: 12px

.hunk-toolbar-count
  color: #ccc
  white-space: nowrap

.hunk-toolbar-actions
  display: flex
  gap: 6px

.hunk-toolbar-button
  padding: 2px 10px
  border-radius: 3px
  cursor: pointer
  background: #0e639c
  color: #fff
  font-size: 11px
  white-space: nowrap
  user-select: none

  &:hover
    background: #1177bb

.hunk-toolbar-button-subtle
  background: transparent
  color: #888
  border: 1px solid #3c3c3c

  &:hover
    background: #3c3c3c
    color: #ccc
