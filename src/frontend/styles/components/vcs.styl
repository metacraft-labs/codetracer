// VCS (Version Control System) panel styles.
// Matches the CodeTracer dark theme and is designed for a narrow (~200px)
// left-sidebar panel.

.vcs-container
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden
  background: colors-ui-surface-base-panel
  color: TEXT_CONTENT_COLOR
  font-family: "SpaceMono", monospace
  line-height: 1.25em

.vcs-panel-body
  display: flex
  flex: 1 1 auto
  flex-direction: column
  min-height: 0
  overflow: hidden

// ---------------------------------------------------------------------------
// No-repo placeholder
// ---------------------------------------------------------------------------

.vcs-no-repo
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  height: 100%
  color: VALUE_TYPE_COLOR
  gap: 0.75em

.vcs-no-repo-icon
  font-size: 2em
  opacity: 0.5

.vcs-no-repo-message
  font-size: 0.8125em
  text-align: center
  padding: 0 1em

// ---------------------------------------------------------------------------
// Branch picker
// ---------------------------------------------------------------------------

.vcs-branch-picker
  position: relative
  flex-shrink: 0
  padding: 0.25em
  background: colors-ui-surface-base-panel

// Styled to match .ct-input-small — consistent with other panel input fields.
.vcs-branch-current
  display: flex
  align-items: center
  height: 1.5rem
  max-height: 1.5rem
  padding: 0 0.5em
  cursor: pointer
  gap: 0.375em
  user-select: none
  border-radius: 0.375rem
  border: 0.03125em solid transparent
  background: colors-ui-surface-primary-default
  font-family: "SpaceGrotesk"
  font-size: 0.875rem
  color: colors-ui-text-primary-label

  &:hover
    border-color: colors-ui-border-primary-hover
    color: colors-ui-text-primary-body

  // Open/active state: thin blue border (like lm_controls active dropdown)
  &.vcs-branch-current-open
    border-color: colors-ui-border-action
    color: colors-ui-text-primary-body

.vcs-branch-chevron
  display: flex
  align-items: center
  flex-shrink: 0
  opacity: 0.7

.vcs-branch-name
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

.vcs-branch-dropdown
  position: absolute
  top: calc(100% + 0.125em)
  left: 0.25em
  right: 0.25em
  z-index: 100
  background: colors-ui-surface-primary-default
  border: 0.03125em solid colors-ui-border-primary
  border-radius: 0.375rem
  max-height: 12.5em
  overflow-y: auto

.vcs-branch-option
  padding: 0.3125em 0.5em
  cursor: pointer
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  font-family: "SpaceGrotesk"
  font-size: 0.875rem
  color: colors-ui-text-primary-label

  &:hover
    background: colors-ui-surface-primary-secondary-hover
    color: colors-ui-text-primary-body

.vcs-branch-active-marker
  color: #4ec9b0
  font-weight: bold

// ---------------------------------------------------------------------------
// Section headers
// ---------------------------------------------------------------------------

.vcs-section-header
  padding: 0.25em 0.5em
  font-size: 0.6875em
  font-weight: 600
  text-transform: uppercase
  letter-spacing: 0.03125em
  color: VALUE_TYPE_COLOR
  background: colors-ui-surface-base-panel
  border-bottom: 1px solid colors-ui-border-secondary
  flex-shrink: 0
  user-select: none

.vcs-changed-files-commit
  font-family: "SpaceMono", monospace
  font-size: 0.625em
  font-weight: 400
  text-transform: none
  letter-spacing: 0
  color: VALUE_TYPE_COLOR

// ---------------------------------------------------------------------------
// Unified diff mode toggle
// ---------------------------------------------------------------------------

.vcs-diff-toggle
  flex: 0 0 auto
  display: flex
  align-items: center
  gap: 0.375em
  padding: 0.375em 0.5em
  border-bottom: 1px solid colors-ui-border-secondary
  background: colors-ui-surface-base-panel

.vcs-toggle-button
  height: 1.5em
  display: inline-flex
  align-items: center
  padding: 0 0.625em
  border-radius: 0.25em
  cursor: pointer
  color: DROPDOWN_TEXT_COLOR
  background: colors-ui-surface-primary-secondary
  user-select: none
  font-size: 0.75em

  &:hover
    background: colors-ui-surface-primary-secondary-hover
    color: TEXT_CONTENT_COLOR

  &.vcs-toggle-active
    background: colors-ui-surface-primary-secondary-hover
    color: TEXT_CONTENT_COLOR

// ---------------------------------------------------------------------------
// Commit graph + accordion history
// ---------------------------------------------------------------------------

.vcs-commit-history
  flex: 1
  display: flex
  flex-direction: column
  min-height: 0
  border-bottom: 1px solid colors-ui-border-secondary

.vcs-commit-list
  flex: 1
  overflow-y: auto
  overflow-x: hidden

// One accordion entry: the header row + optional expanded file list.
// flex-direction:column stacks the header and the file list vertically.
// No border-bottom — a horizontal border would cut through the lane lines.
.vcs-commit-entry
  display: flex
  flex-direction: column

// Header row: [graph area] [message] [time]
// align-items:stretch makes the lane-graph column fill the row height so the
// vertical lane lines span the full row.  Do NOT add flex-direction:column
// here — the graph column and message body must stay side-by-side (row).
.vcs-commit-header
  display: flex
  flex-direction: row
  align-items: stretch
  min-height: 1em
  cursor: pointer
  user-select: none

  &:hover
    background: ACTIVE_ROW

  // On the selected (active) row, hover uses the darker action-primary shade
  // so it reads as a pressed / deepened state rather than flipping to grey.
  &.vcs-commit-header-selected:hover
    background: colors-ui-surface-action-primary-hover

// Selected commit: uses colors-ui-surface-action-primary (#4f46e5) background.
// The dot becomes white with a border matching the row background so it
// visually "punches through" the fill.  Text is forced white for contrast.
.vcs-commit-header-selected
  background: colors-ui-surface-action-primary

  .vcs-commit-msg
    color: #ffffff

  .vcs-commit-time-col
    color: rgba(255, 255, 255, 0.7)

  // Active solid dot: white fill, outline matches the row background so the
  // ring sits outside the dot without eating into the white area.
  .vcs-gc-dot:not(.vcs-gc-dot-hollow)
    background: colors-base-white !important
    outline-color: colors-ui-surface-action-primary !important
    outline-width: 0.125em !important

  // Active hollow dot (branch-out / merge-in commit): keep the dark panel
  // background visible through the centre; halo outline matches the row
  // background so the floating effect is consistent with the solid dot.
  .vcs-gc-dot-hollow
    background: colors-ui-surface-base-panel !important
    outline-color: colors-ui-surface-action-primary !important
    border-color: colors-base-white !important

// Left graph column: flex row of vcs-gc-slot lane cells.
// position:relative is required so that the absolute-positioned connector
// divs (.vcs-gc-conn-r / .vcs-gc-conn-l) are placed relative to the
// left edge of the graph area.  overflow:hidden prevents connectors from
// bleeding into the commit-message column.
.vcs-commit-graph
  position: relative
  display: flex
  align-items: stretch
  flex-shrink: 0
  overflow: hidden

// One lane column slot — 0.5em wide so it scales with the component font-size.
.vcs-gc-slot
  position: relative
  flex: 0 0 0.5em
  min-width: 0.5em
  max-width: 0.5em

// Full-height vertical lane bar (gckLine and gckDot lanes).
// Horizontally centred in the 1em slot.
.vcs-gc-line
  position: absolute
  left: calc(50% - 0.05em)
  top: 0
  bottom: 0
  width: 0.1em

// Bottom-half-only bar: used on the first (newest) commit so that no line
// appears above the topmost dot.
.vcs-gc-line-bot
  position: absolute
  left: calc(50% - 0.05em)
  top: 50%
  bottom: 0
  width: 0.1em

// Dot centred on the row (gckDot lane).
// outline instead of border so the ring sits outside the dot box and does
// not shrink the coloured area.  outline follows border-radius in Chromium.
.vcs-gc-dot
  position: absolute
  left: 50%
  top: 50%
  transform: translate(-50%, -50%)
  width: 0.375em
  height: 0.375em
  border-radius: 50%
  outline: 0.0625em solid colors-ui-surface-base-panel
  z-index: 1

// Hollow ring dot: used for commits that have branch-outs or merge-ins.
// border carries the branch colour (set via inline style); outline sits
// outside the border and uses the panel background colour so the dot
// appears to float above the lane line.
.vcs-gc-dot-hollow
  background: colors-ui-surface-base-panel
  outline: 0.0625em solid colors-ui-surface-base-panel
  border-width: 0.125em
  border-style: solid

// Right-angle connectors — stroke weight matches the lane line (0.1em).
// border-radius on the corner creates the smooth curve.
.vcs-gc-conn-r
  position: absolute
  top: 50%
  height: 50%
  border-right: 0.1em solid
  border-top: 0.1em solid
  border-top-right-radius: 0.5em
  background: none
  box-sizing: border-box
  pointer-events: none

// Right-angle connector: dot lane → target lane to the LEFT.
.vcs-gc-conn-l
  position: absolute
  top: 50%
  height: 50%
  border-left: 0.1em solid
  border-top: 0.1em solid
  border-top-left-radius: 0.5em
  background: none
  box-sizing: border-box
  pointer-events: none

// Top-half right-angle connector: side lane to the RIGHT curves into dot lane.
.vcs-gc-conn-tr
  position: absolute
  top: 0
  height: 50%
  border-right: 0.1em solid
  border-bottom: 0.1em solid
  border-bottom-right-radius: 0.5em
  background: none
  box-sizing: border-box
  pointer-events: none

// Top-half right-angle connector: side lane to the LEFT curves into dot lane.
.vcs-gc-conn-tl
  position: absolute
  top: 0
  height: 50%
  border-left: 0.1em solid
  border-bottom: 0.1em solid
  border-bottom-left-radius: 0.5em
  background: none
  box-sizing: border-box
  pointer-events: none

// Right body column: message + timestamp.
.vcs-commit-body
  flex: 1
  display: flex
  align-items: center
  padding: 0 0.5em
  gap: 0.5em
  min-width: 0

.vcs-commit-msg
  flex: 1
  font-size: 0.75em
  color: colors-ui-text-primary-body-subtle
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.vcs-commit-time-col
  font-family: "SpaceMono", monospace
  font-size: 0.625em
  color: colors-ui-text-primary-body-subtle
  flex-shrink: 0

// Diff button shown on hover at the far right of a commit row.
// Hidden by default; the parent .vcs-commit-header:hover reveals it.
.vcs-commit-diff-btn
  display: none
  flex-shrink: 0
  position: relative
  cursor: pointer
  width: 0.6875em
  height: 0.8125em
  margin: 0 0.25em
  background-image: url("../../public/resources/shared/vc-open-diff.svg")
  background-repeat: no-repeat
  background-size: contain
  background-position: center

  .custom-tooltip
    right: 0
    left: unset
    z-index: 200

    // Arrow: override centered default to sit under the icon button.
    // Icon is 0.6875em wide, right-aligned → arrow at right edge of tooltip.
    &:after
      left: unset
      right: 0.25em

.vcs-commit-header:hover .vcs-commit-diff-btn
  display: block

.vcs-commit-diff-btn:hover > .custom-tooltip
  opacity: 1
  visibility: visible
  top: calc(100% + 0.3125em)
  transition-delay: TOOLTIP_DELAY_TIMER

// ---------------------------------------------------------------------------
// Accordion expanded area: file list rendered inline under the commit header.
// ---------------------------------------------------------------------------

// Commit-detail tooltip.
// Shown on hover of a commit header row.  position:fixed lets it escape the
// panel's overflow:hidden so it can appear to the right of the panel.
// Populated and positioned by JS (showVCSTooltip / hideVCSTooltip).
// 3-second delay + fade-in is driven by JS adding/removing .vcs-tip-visible.
// Two-column layout: left = hash + rows, right = author badge + copy button.
.vcs-commit-tooltip
  opacity: 0
  visibility: hidden
  transition: opacity 0.3s ease, visibility 0.3s ease
  position: fixed
  z-index: 1000
  display: flex
  gap: 0.75em
  background: colors-ui-surface-base-raised
  border: 0.0625em solid colors-ui-border-secondary
  border-radius: 0.5em
  padding: 0.625em
  min-width: 16.25em
  max-width: 26.25em
  box-shadow: 0 0.25em 1.25em rgba(0, 0, 0, 0.5)
  font-family: "SpaceGrotesk"
  font-size: 0.75em

// Left column: hash on its own line, then label/value rows.
.vcs-tip-left
  flex: 1
  min-width: 0

// Right column: author badge pinned top, copy button pinned bottom.
.vcs-tip-right
  display: flex
  flex-direction: column
  align-items: flex-end
  justify-content: space-between
  flex-shrink: 0

.vcs-tip-hash
  display: block
  color: colors-ui-text-primary-label
  font-weight: 600
  letter-spacing: 0.03125em
  white-space: nowrap
  margin-bottom: 0.625em

// Author-initial avatar.
.vcs-tip-dot
  width: 2em
  height: 2em
  border-radius: 50%
  flex-shrink: 0
  background: colors-ui-text-primary-active
  color: colors-ui-text-on-color-body
  font-family: "SpaceGrotesk"
  font-size: 0.625em
  font-weight: 600
  display: flex
  align-items: center
  justify-content: center

// A label + value row inside the tooltip (DATE, COMMIT, AUTHOR).
.vcs-tip-row
  display: flex
  align-items: baseline
  gap: 0.5em
  margin-top: 0.375em
  line-height: 1em
  color: TEXT_CONTENT_COLOR
  word-break: break-all

.vcs-tip-label
  color: VALUE_TYPE_COLOR
  text-transform: uppercase
  flex-shrink: 0

// Copy-to-clipboard icon button, pinned to bottom of right column.
.vcs-tip-copy
  display: block
  cursor: pointer
  width: 0.8125em
  height: 0.8125em
  background-image: url("../../public/resources/shared/vcs-copy-details.svg")
  background-repeat: no-repeat
  background-size: contain
  background-position: center
  opacity: 0.6

  &:hover
    opacity: 1

// Inline file rows inside an expanded accordion entry.
.vcs-accordion-files
  background: colors-ui-surface-base-canvas

// Outer file row: flex row so lane spacer and content sit side by side.
// align-items:stretch lets the lane spacer column fill the full row height.
// font-size is NOT set here — the lane spacer (.vcs-commit-graph) must share
// the same em context as the commit header rows so 1em slots stay aligned.
.vcs-accordion-file
  display: flex
  align-items: stretch
  padding: 0
  cursor: pointer

  &:hover
    background: colors-ui-surface-primary-default-hover

// Inner content area of an accordion file row (status + name + stats).
// font-size: 0.75em is scoped here so the lane spacer sibling is unaffected.
.vcs-accordion-file-body
  flex: 1
  display: flex
  align-items: center
  gap: 0.5em
  padding: 0.125em 0.5em
  font-size: 0.75em

// File name: takes remaining space, truncates with ellipsis.
.vcs-accordion-file-name
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  color: TEXT_CONTENT_COLOR

// Status letter (M / A / D / …) shown right of the stats.
.vcs-accordion-file-status
  font-family: "SpaceMono", monospace
  font-weight: 700
  flex-shrink: 0
  width: 1em
  text-align: center
  order: 1

// +N additions and -N deletions shown to the right of the filename,
// matching the reference screenshot layout.
.vcs-accordion-file-adds
  font-family: "SpaceMono", monospace
  color: colors-ui-text-success-primary
  flex-shrink: 0

.vcs-accordion-file-dels
  font-family: "SpaceMono", monospace
  color: colors-ui-text-error-primary
  flex-shrink: 0

// Status letter colours (mirror the existing vcs-status-* palette).
.vcs-accordion-status-added    { color: colors-ui-text-success-primary }
.vcs-accordion-status-deleted  { color: colors-ui-text-error-primary }
.vcs-accordion-status-modified { color: colors-ui-text-warning-primary }
.vcs-accordion-status-copied   { color: CT_SECONDARY_BLUE }
.vcs-accordion-status-renamed  { color: #A78BFA }
.vcs-accordion-status-other    { color: VALUE_TYPE_COLOR }

// "Loading more commits…" row at the bottom during a background page fetch.
// The IntersectionObserver sentinel element is an empty sibling; this row is
// the visible indicator for the user.
.vcs-load-more-sentinel
  padding: 0.5em 0.75em
  font-size: 0.6875em
  color: VALUE_TYPE_COLOR
  text-align: center
  font-family: "SpaceMono", monospace

// Legacy flat commit items (kept for DeepReview / unified-diff code paths that
// still call the old rendering procs; not used in the new graph mode).
.vcs-commit-item
  display: flex
  flex-direction: column
  padding: 0.25em 0.5em
  cursor: pointer
  border-bottom: 1px solid EVENT_LOG_ROWS_BORDERS_COLOR
  gap: 0.0625em

  &:hover
    background: ACTIVE_ROW

.vcs-commit-selected
  background: ACTIVE_ROW !important

.vcs-commit-hash
  font-family: "SpaceMono", monospace
  font-size: 0.6875em
  color: #4ec9b0
  flex-shrink: 0

.vcs-commit-message
  font-size: 0.75em
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  color: TEXT_CONTENT_COLOR

.vcs-commit-time
  font-size: 0.625em
  color: VALUE_TYPE_COLOR


// ---------------------------------------------------------------------------
// Changed files
// ---------------------------------------------------------------------------

.vcs-changed-files
  flex: 1
  display: flex
  flex-direction: column
  min-height: 0

.vcs-file-list
  flex: 1
  overflow-y: auto
  overflow-x: hidden

.vcs-no-files
  padding: 0.5em
  color: VALUE_TYPE_COLOR
  font-style: italic
  text-align: center

.vcs-file-item
  display: flex
  align-items: center
  padding: 0.1875em 0.5em
  cursor: pointer
  gap: 0.375em

  &:hover
    background: ACTIVE_ROW

.vcs-file-selected
  background: ACTIVE_ROW

.vcs-file-status
  font-family: "SpaceMono", monospace
  font-size: 0.6875em
  font-weight: bold
  width: 1em
  text-align: center
  flex-shrink: 0

.vcs-status-added
  color: #4ec9b0

.vcs-status-deleted
  color: #f44747

.vcs-status-modified
  color: #e5c07b

.vcs-status-other
  color: #888

.vcs-file-name
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-size: 0.75em

.vcs-file-stats
  font-family: "SpaceMono", monospace
  font-size: 0.625em
  flex-shrink: 0
  display: flex
  gap: 0.25em

.vcs-stat-added
  color: #4ec9b0

.vcs-stat-deleted
  color: #f44747

// ---------------------------------------------------------------------------
// Refresh button
// ---------------------------------------------------------------------------

.vcs-refresh
  flex-shrink: 0
  padding: 0.25em 0.5em
  text-align: center
  cursor: pointer
  font-size: 0.6875em
  color: VALUE_TYPE_COLOR
  background: colors-ui-surface-base-panel
  border-top: 1px solid colors-ui-border-secondary
  user-select: none

  &:hover
    background: colors-ui-surface-primary-secondary-hover
    color: TEXT_CONTENT_COLOR

// ---------------------------------------------------------------------------
// Hunk editor: selection, toolbar, and visual indicators
// ---------------------------------------------------------------------------

.hunk-header-selectable
  cursor: pointer
  user-select: none
  transition: background 0.1s ease

  &:hover
    background: colors-ui-surface-primary-secondary-hover

.hunk-selected
  border-left: 0.1875em solid #569cd6
  background: rgba(86, 156, 214, 0.08)

  .deepreview-unified-hunk-header
    background: rgba(86, 156, 214, 0.15)

.hunk-selection-indicator
  display: inline-block
  margin-right: 0.375em
  color: #569cd6
  font-size: 0.75em
  font-weight: bold

// Floating toolbar shown when hunks are selected.
.hunk-toolbar
  position: sticky
  top: 0
  z-index: 50
  display: flex
  align-items: center
  justify-content: space-between
  padding: 0.25em 0.625em
  background: colors-ui-surface-base-panel
  border: 1px solid colors-ui-border-secondary
  border-radius: 0.25em
  margin: 0.25em 0 0.375em 0
  box-shadow: 0 0.125em 0.5em rgba(0, 0, 0, 0.3)
  font-size: 0.75em

.hunk-toolbar-count
  color: TEXT_CONTENT_COLOR
  white-space: nowrap

.hunk-toolbar-actions
  display: flex
  gap: 0.375em

.hunk-toolbar-button
  padding: 0.125em 0.625em
  border-radius: 0.1875em
  cursor: pointer
  background: #0e639c
  color: #fff
  font-size: 0.6875em
  white-space: nowrap
  user-select: none

  &:hover
    background: #1177bb

.hunk-toolbar-button-subtle
  background: transparent
  color: VALUE_TYPE_COLOR
  border: 1px solid colors-ui-border-secondary

  &:hover
    background: colors-ui-surface-primary-secondary-hover
    color: TEXT_CONTENT_COLOR
