#command-data
  height: 28px

.command-container
  height: 100%
  width: 100%
  display: flex
  align-items: flex-start
  justify-content: center
  padding-top: 10vh
  background: rgba(27, 27, 27, 0.96)
  box-sizing: border-box
  font-family: "SpaceGrotesk", sans-serif

  &.hidden
    display: none

.command-view
  font-size: 16px
  z-index: 9999
  width: calc(100vw - 5em)
  max-width: 48em
  color: TEXT_CONTENT_COLOR

  .command-input-row
    position: relative
    height: 2.875em
    display: flex
    align-items: center
    background: #151515
    border: 0.0625em solid #4f4f4f
    border-radius: 0.75em 0.75em 0 0
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.35)

  .command-input-field
    width: 100%
    height: 100%
    border: 0
    outline: 0
    background: transparent
    color: TEXT_CONTENT_COLOR
    padding: 0 1em
    font-size: 1em
    font-family: "SpaceGrotesk", sans-serif

  .command-input-placeholder
    position: absolute
    left: 4.6em
    right: 1em
    pointer-events: none
    color: VALUE_TYPE_COLOR
    opacity: 0.45
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis

  .command-results
    width: 100%
    max-height: 24em
    overflow-y: auto
    background-color: COMMAND_RESULT_BACKGROUND_COLOR
    border: 0.0625em solid #4f4f4f
    border-top: 0
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.4)
    border-bottom-left-radius: 0.75em
    border-bottom-right-radius: 0.75em

    &.hidden
      display: none

  .command-empty-overlay
    padding: 0.75em 1em
    color: VALUE_TYPE_COLOR
    background: COMMAND_RESULT_BACKGROUND_COLOR
    border: 0.0625em solid #4f4f4f
    border-top: 0

    &.hidden
      display: none

  .command-surface
    position: relative
    border-radius: 0.75em

  .command-surface-open
    overflow: visible

  .agent-com
    max-height: 40vh

  .ct-input-cp-background
    background: AGENT_BACKGROUND !important
    padding-left: 8px !important

  .agent-command-input
    color: #A5F3FC !important

    &::placeholder
      color: #a5f3fc

  #command-results
    width: 100%
    max-height: 18em
    overflow-y: auto
    background-color: COMMAND_RESULT_BACKGROUND_COLOR
    border: 0.03125em solid colors-ui-border-primary
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.4)
    margin-top: 0
    border-bottom-left-radius: 0.75em
    border-bottom-right-radius: 0.75em

  .command-results-open
    margin-top: 0

  .command-results-empty
    min-height: 2.75em

  .command-result
    background-color: COMMAND_RESULT_BACKGROUND_COLOR
    color: TEXT_CONTENT_COLOR
    display: flex
    align-items: center
    gap: 0.75em
    font-size: 0.875em
    position: relative
    min-height: 2.5em
    width: 100%
    line-height: 1.25
    border-radius: 0
    padding: 0.5em 0.75em
    overflow: hidden
    cursor: pointer
    opacity: 1

    & + .command-result
      border-top: 0.03125em solid colors-ui-border-primary

    &.empty
      justify-content: center
      color: VALUE_TYPE_COLOR

    &:hover
      background-color: COMMAND_RESULT_HOVERED_BACKGROUND_COLOR

    b
      color: COMMAND_HIGHLIGHTED_RESULT_TEXT_COLOR

  .no-results
    display: none

  .command-even
    // background-color: COMMAND_EVEN_BACKGROUND_COLOR
    // color: COMMAND_ODD_BACKGROUND_COLOR

  .command-odd
    // background-color: COMMAND_ODD_BACKGROUND_COLOR
    // color: COMMAND_EVEN_BACKGROUND_COLOR

  .command-selected
    background-color: COMMAND_RESULT_SELECTED_BACKGROUND_COLOR !important
    color: COMMAND_RESULT_SELECTED_TEXT_COLOR !important



.command-non-active
  display: none

#fixed-search
  font-size: 20px
  position: fixed
  left: 40vw
  width: 20vw
  right: 40vw
  top: 20px
  z-index: 5

.fixed-search-non-active
  display: none

#fixed-search .search-results
  font-size: 20px
  background-color: BACKGROUND_COLOR
  color: COLOR
  position: fixed
  bottom: 20px
  max-height: 40vh
  overflow: scroll
  cursor: pointer

  .search-results-location
    width: 50vw
    background-color: #eee

  .search-results-text
    width: 50vw

#fixed-search .search-results-active
  display: block

#fixed-search .search-results-non-active
  display: none

.command-program-search-result-value > div
  font-family: monospace
  display: inline

.command-program-search-result
  display: flex
  align-items: baseline
  gap: 0.75em
  width: 100%
  min-width: 0

.command-program-search-result-value
  flex: 1 1 auto
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis

.command-program-search-result-source
  flex: 0 1 35%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  color: VALUE_TYPE_COLOR
  font-size: 0.8em
  opacity: 0.85

.command-program-search-result-location
  flex: 0 1 40%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  font-weight: lighter
  font-size: 0.75em
  float: none
  padding-right: 0
  color: VALUE_TYPE_COLOR
  opacity: 0.85

.command-program-search-result-line
  flex: 0 0 auto
  font-weight: normal
  color: VALUE_TYPE_COLOR
  opacity: 0.85
