#command-data
  height: 28px

.command-view
  font-size: inherit
  z-index: 9999
  left: 35vw
  width: 30vw
  right: 35vw

  .command-surface
    position: relative
    border-radius: 0.75em

  .command-surface-open
    overflow: visible

  .agent-com
    max-height: 40vh

  .ct-input-cp-background
    background: AGENT_BACKGROUND !important
    padding-left: 8px !important

  .agent-command-input
    color: #A5F3FC !important

    &::placeholder
      color: #a5f3fc

  #command-results
    width: 100%
    max-height: 18em
    overflow-y: auto
    overflow-x: hidden
    background-color: colors-ui-surface-raised
    border: 0.03125em solid colors-ui-border-primary
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.4)
    margin-top: 0
    border-bottom-left-radius: 0.75em
    border-bottom-right-radius: 0.75em
    overflow: hidden

    .command-result:last-child
      border-bottom: none

  .command-results-open
    margin-top: 0

  .command-results-empty
    min-height: 2.75em

  .command-result
    gap: 0.75em
    font-size: 0.875em
    position: relative
    overflow: hidden

    &.empty
      display: flex
      justify-content: center
      align-items: center
      min-height: 2.75em
      color: VALUE_TYPE_COLOR

    b
      color: colors-ui-text-primary-active

  .no-results
    display: none

  .command-even
    // background-color: COMMAND_EVEN_BACKGROUND_COLOR

  .command-odd
    // background-color: COMMAND_ODD_BACKGROUND_COLOR



.command-non-active
  display: none

#fixed-search
  font-size: 20px
  position: fixed
  left: 40vw
  width: 20vw
  right: 40vw
  top: 20px
  z-index: 5

.fixed-search-non-active
  display: none

.search-results
  font-size: 20px
  background-color: BACKGROUND_COLOR
  color: COLOR
  position: fixed
  bottom: 20px
  max-height: 40vh
  overflow: scroll
  cursor: pointer

  .search-results-location
    width: 50vw
    background-color: #eee

  .search-results-text
    width: 50vw

.search-results-active
  display: block

.search-results-non-active
  display: none

.command-program-search-result-value > div
  font-family: monospace
  display: inline

.command-program-search-result
  display: flex
  align-items: baseline
  gap: 0.75em
  width: 100%
  min-width: 0

.command-program-search-result-value
  flex: 1 1 auto
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis

.command-program-search-result-source
  flex: 0 1 35%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  color: VALUE_TYPE_COLOR
  font-size: 0.8em
  opacity: 0.85

.command-program-search-result-location
  flex: 0 1 40%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  font-weight: lighter
  font-size: 0.75em
  float: none
  padding-right: 0
  color: VALUE_TYPE_COLOR
  opacity: 0.85

.command-program-search-result-line
  flex: 0 0 auto
  font-weight: normal
  color: VALUE_TYPE_COLOR
  opacity: 0.85
