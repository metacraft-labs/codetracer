#command-data
  height: 28px

.command-container
  height: 100%
  width: 100%
  display: flex
  align-items: flex-start
  justify-content: center
  padding-top: 10vh
  background: rgba(27, 27, 27, 0.96)
  box-sizing: border-box
  font-family: "SpaceGrotesk", sans-serif

  &.hidden
    display: none

.command-view
  font-size: 16px
  z-index: 9999
  width: calc(100vw - 5em)
  max-width: 48em
  color: TEXT_CONTENT_COLOR

  .command-input-row
    position: relative
    height: 2.875em
    display: flex
    align-items: center
    background: #151515
    border: 0.0625em solid #4f4f4f
    border-radius: 0.75em 0.75em 0 0
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.35)

  .command-input-field
    width: 100%
    height: 100%
    border: 0
    outline: 0
    background: transparent
    color: TEXT_CONTENT_COLOR
    padding: 0 1em
    font-size: 1em
    font-family: "SpaceGrotesk", sans-serif

  .command-input-placeholder
    position: absolute
    left: 4.6em
    right: 1em
    pointer-events: none
    color: VALUE_TYPE_COLOR
    opacity: 0.45
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis

  .command-results
    width: 100%
    max-height: 24em
    overflow-y: auto
    background-color: COMMAND_RESULT_BACKGROUND_COLOR
    border: 0.0625em solid #4f4f4f
    border-top: 0
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.4)
    border-bottom-left-radius: 0.75em
    border-bottom-right-radius: 0.75em

    &.hidden
      display: none

  .command-empty-overlay
    padding: 0.75em 1em
    color: VALUE_TYPE_COLOR
    background: COMMAND_RESULT_BACKGROUND_COLOR
    border: 0.0625em solid #4f4f4f
    border-top: 0

    &.hidden
      display: none

  .command-surface
    position: relative
    border-radius: 0.75em

  .command-surface-open
    overflow: visible

  .agent-com
    max-height: 40vh

  .ct-input-cp-background
    background: AGENT_BACKGROUND !important
    padding-left: 8px !important

  .agent-command-input
    color: #A5F3FC !important

    &::placeholder
      color: #a5f3fc

  #command-results
    width: 100%
    font-size: 0.875em
    max-height: 18em
    overflow-y: auto
    overflow-x: hidden
    background-color: colors-ui-surface-raised
    border: 0.0625em solid colors-ui-border-tertiary
    box-shadow: 0 0.75em 2.5em rgba(0, 0, 0, 0.4)
    margin-top: 0.25rem
    border-radius: 0.75em
    overflow: hidden

    .command-result:last-child
      border-bottom: none

  .command-results-open
    margin-top: 0

  .command-result.empty
      font-family: "SpaceGrotesk"

  .command-result
    gap: 0.75em
    font-size: 0.875em
    position: relative
    overflow: hidden

    &.empty
      display: flex
      justify-content: center
      align-items: center
      min-height: 2.75em
      color: VALUE_TYPE_COLOR

    b
      color: colors-ui-text-primary-active

  .no-results
    display: none

  .command-even
    // background-color: COMMAND_EVEN_BACKGROUND_COLOR

  .command-odd
    // background-color: COMMAND_ODD_BACKGROUND_COLOR



.command-non-active
  display: none

#fixed-search
  font-size: 20px
  position: fixed
  left: 40vw
  width: 20vw
  right: 40vw
  top: 20px
  z-index: 5

.fixed-search-non-active
  display: none

#fixed-search .search-results
  font-size: 20px
  background-color: BACKGROUND_COLOR
  color: COLOR
  position: fixed
  bottom: 20px
  max-height: 40vh
  overflow: scroll
  cursor: pointer

  .search-results-location
    width: 50vw
    background-color: #eee

  .search-results-text
    width: 50vw

#fixed-search .search-results-active
  display: block

#fixed-search .search-results-non-active
  display: none

.command-program-search-result-value > div
  font-family: monospace
  display: inline

.command-program-search-result
  display: flex
  align-items: baseline
  gap: 0.75em
  width: 100%
  min-width: 0

.command-program-search-result-value
  flex: 1 1 auto
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis

.command-program-search-result-source
  flex: 0 1 35%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  color: VALUE_TYPE_COLOR
  font-size: 0.8em
  opacity: 0.85

.command-program-search-result-location
  flex: 0 1 40%
  min-width: 0
  overflow: hidden
  white-space: nowrap
  text-overflow: ellipsis
  font-weight: lighter
  font-size: 0.75em
  float: none
  padding-right: 0
  color: VALUE_TYPE_COLOR
  opacity: 0.85

.command-program-search-result-line
  flex: 0 0 auto
  font-weight: normal
  color: VALUE_TYPE_COLOR
  opacity: 0.85

#menu #debug
  > .component-container
    display: flex
    align-items: center
    justify-content: center
    width: 100%
    height: 100%

  .command-container
    display: flex !important
    height: 100%
    width: 48em
    padding-top: 0
    background: transparent
    box-sizing: border-box
    align-items: center
    justify-content: center

    &.hidden
      display: flex !important

  .command-view
    width: 100%
    max-width: 48em
    font-size: 0.75rem
    z-index: 25

    .command-input-row
      height: 1.75rem
      border-radius: 0.375rem
      background: colors-ui-surface-primary-default
      box-shadow: none

    .command-input-field
      font-size: 0.75rem
      padding: 0 0.75rem

    .command-input-placeholder
      left: 0.75rem
      right: 0.75rem

    .command-results,
    .command-empty-overlay
      display: none

  .command-container:not(.hidden)
    .command-results
      display: block
      position: absolute
      top: 1.75rem

    .command-empty-overlay:not(.hidden)
      display: block
      position: absolute
      top: 1.75rem
