.traceLog
  display: flex;
  flex-direction: column;
  color: COLOR
  height: 100%
  min-height: 0
  overflow: hidden

  .trace-log-table-header
    display: grid
    grid-template-columns: 120px 160px 180px minmax(0, 1fr)
    flex: 0 0 24px
    align-items: center
    border-bottom: 1px solid ACTIVE_MENU_BACKGROUND
    color: VALUE_TYPE_COLOR
    font-family: "FiraCode"
    font-size: 13px
    line-height: 20px
    padding: 0 8px

  .trace-log-table-body
    flex: 1 1 auto
    min-height: 0
    overflow-y: auto
    overflow-x: hidden
    font-family: "FiraCode"
    font-size: 13px
    line-height: 20px

  .trace-log-row
    display: grid
    grid-template-columns: 120px 160px 180px minmax(0, 1fr)
    min-height: 24px
    align-items: center
    border-top: 1px solid EVENT_LOG_ROWS_BORDERS_COLOR
    color: TEXT_CONTENT_COLOR
    padding: 0 8px
    cursor: pointer

    &:hover,
    &.selected
      background: ACTIVE_ROW

  .trace-col-rr-ticks,
  .trace-col-location,
  .trace-col-function,
  .trace-col-locals
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

  .trace-col-rr-ticks
    position: relative
    padding-left: 4px

    .event-rr-ticks-line
      position: absolute
      left: 0
      right: 12px
      bottom: 4px
      height: 2px
      background: CT_SECONDARY_BLUE

  .trace-log-empty
    padding: 12px 8px
    color: VALUE_TYPE_COLOR
    font-family: "FiraCode"
    font-size: 13px

    &.hidden
      display: none

  .trace-location
    width: 20%

  .trace-function-name
    width: 10%

  .trace-values
    width: 45%
    cursor: pointer
    text-overflow: ellipsis
    overflow: visible
    white-space: nowrap
    display: flex


.trace-main
  // stop:8px
  top: 8px
  background-color: BACKGROUND_COLOR
  color: COLOR
  // width: calc(100%+71px)
  width: 100% !important
  padding-right: 1ch
  // height: 36ch
  position: absolute
  if IS_EXTENSION
    max-width: calc(100% - 15px)
  // left: -81px

  .editor-textarea
    z-index: TRACE_LOG_EDITOR_Z_INDEX + 5

  .cursor
    z-index: TRACE_LOG_EDITOR_Z_INDEX + 4

  .view-overlays.focused
    z-index: TRACE_LOG_EDITOR_Z_INDEX + 3
    opacity: 0.4
    cursor: text

  .view-overlays
    z-index: 5
    cursor: text

  .view-lines
    z-index: TRACE_LOG_EDITOR_Z_INDEX + 1

  .trace-view
    position: relative
    width: 100%
    display: flex
    flex: 1 1 0
    height: 100%
    flex-direction: column
    min-height: 0
    overflow: hidden

    .chart-results-container
      display: flex
      flex: 1 1 auto
      flex-direction: column
      width: 100%
      height: 100%
      min-height: 0
      overflow: hidden

    .dt-scroll
      overflow-x: auto !important

    .dt-scroll-body
      overflow-x: auto !important
      overflow-y: auto !important

    .trace-table
      width: max-content !important
      min-width: 100%
      max-width: none

      tbody
        width: max-content
        min-width: 100%

    .direct-location-rr-ticks
      transform: translateY(0)
      padding-top: 0.125em
      flex: 0 0 auto
      min-width: max-content

    tbody
      tr
        height: 1.5em
        width: max-content
        min-width: 100%

      td
        height: 1.5em
        flex-shrink: 0

    .rr-ticks-time-container
      height: 1em
      line-height: normal

    .trace-line
      width: 20%
      color: COLOR

    .trace-values
      padding-top: 0.25em !important
      line-height: 1em !important
      width: auto
      min-width: max-content
      flex: 0 0 auto
      color: TEXT_CONTENT_COLOR
      cursor: pointer
      overflow: visible
      white-space: nowrap
      display: block

      // &:hover
      //   overflow-x: overlay !important

      //   &::-webkit-scrollbar-thumb:horizontal
      //     border: 0px !important
      //     background-color: PRIMARY_BASE

      //   &::-webkit-scrollbar
      //     height: 4px !important

    // .odd, .even
    //  opacity: 0.5

    .direct-location-rr-ticks
      width: 20%
      height: 1.375em

    .chart-table
      width: 100%
      display: flex
      flex: 1 1 auto
      flex-direction: column
      height: 100%
      min-height: 0
      overflow: hidden

  .scrollbar
    .slider
      border-radius: 0.15625em

  .trace-chevron
    position: absolute
    left:50%

    .trace-chevron-baseline
      position: absolute;
      width: 80px;
      height: 2px;
      top: 0;
      background-color: TRACEPOINT_CHEVRON_COLOR;
      z-index: 3;
      left: calc(50% - 40px);
      border-top-left-radius: 2px
      border-top-right-radius: 2px

    .trace-chevron-baseline-cut
      position: absolute;
      width: 10px;
      height: 2px;
      top: 0;
      background-color: TRACEPOINT_BACKGROUND_COLOR;
      z-index: 3;
      left: calc(50% - 5px);

    .trace-chevron-arrow
      color: TRACEPOINT_CHEVRON_COLOR
      cursor: pointer
      position: absolute
      left: 50%
      z-index: 4

      &::before
        border-style: solid
        border-width: 2px 2px 0 0
        content: ''
        display: inline-block
        height: 9px
        left: -4.5px
        position: absolute
        top: -5px
        transform: rotate(315deg)
        vertical-align: top
        width: 9px

  .trace-modal
    border: 1px solid black
    position: relative
    display: none
    margin-left: 60px
    background-color: TRACEPOINT_BACKGROUND_COLOR
    width: 85%
    overflow: visible
    z-index: TRACE_LOG_EDITOR_Z_INDEX + 5

    .value-view
      position: relative !important

    .modal-close-button
      position: absolute
      top: 3px
      right: 0
      height: 17px
      display: flex
      z-index: 2

    .modal-close-button::after
      content: "X"
      font-size: 15px
      font-weight: bold

    .select-kind-button-container
      display: none

    .value-expanded-compound
      height: 100%

    .value-expanded-view
      overflow-x: auto
      background-color: inherit

    .atom-even
      height: 100%
      background-color: inherit

    .atom-odd
      height: 100%
      background-color: inherit


