// HTTP Request Panel — M3
// Follows the dark theme colour variables used across CodeTracer.

.request-panel
  font-family: "FiraCode", monospace
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden
  background: BACKGROUND_COLOR
  color: TEXT_CONTENT_COLOR

// ---------------------------------------------------------------------------
// Header / toolbar
// ---------------------------------------------------------------------------

.request-panel-header
  display: flex
  align-items: center
  justify-content: space-between
  padding: 6px 10px
  flex-shrink: 0
  background: HEADER_PANEL_BACKGROUND_COLOR
  border-bottom: 1px solid ACTIVE_MENU_BACKGROUND

.request-panel-filters
  display: flex
  align-items: center
  gap: 8px

.request-filter-select
  background-color: ACTIVE_MENU_BACKGROUND
  color: DROPDOWN_TEXT_COLOR
  border: 1px solid BORDERS_COLOR
  border-radius: 4px
  height: 26px
  font-size: 12px
  padding: 0 6px
  cursor: pointer
  outline: none

  &:focus
    border-color: CT_PRIMARY_DEFAULT

.request-filter-search
  background-color: ACTIVE_MENU_BACKGROUND
  color: DROPDOWN_TEXT_COLOR
  border: 1px solid BORDERS_COLOR
  border-radius: 4px
  height: 26px
  font-size: 12px
  padding: 0 8px
  min-width: 160px
  outline: none

  &:focus
    border-color: CT_PRIMARY_DEFAULT

  &::placeholder
    color: DROPDOWN_TEXT_COLOR
    opacity: 0.6

.request-panel-count
  font-size: 12px
  color: DROPDOWN_TEXT_COLOR
  white-space: nowrap
  padding-left: 8px

// ---------------------------------------------------------------------------
// Table header
// ---------------------------------------------------------------------------

.request-table-header
  display: flex
  align-items: center
  padding: 4px 10px
  font-weight: 600
  font-size: 12px
  color: DROPDOWN_TEXT_COLOR
  background: HEADER_PANEL_BACKGROUND_COLOR
  border-bottom: 1px solid ACTIVE_MENU_BACKGROUND
  flex-shrink: 0
  user-select: none

// ---------------------------------------------------------------------------
// Table body (scrollable)
// ---------------------------------------------------------------------------

.request-table-body
  flex: 1
  overflow-y: auto
  overflow-x: hidden

// ---------------------------------------------------------------------------
// Rows
// ---------------------------------------------------------------------------

.request-row
  display: flex
  align-items: center
  padding: 3px 10px
  font-size: 12px
  cursor: pointer
  border-bottom: 1px solid EVENT_LOG_ROWS_BORDERS_COLOR
  color: TEXT_CONTENT_COLOR

  &:hover
    background-color: BUTTON_HOVER_BACKGROUND

  &.selected
    background-color: ACTIVE_ROW

// ---------------------------------------------------------------------------
// Column widths (flex-based)
// ---------------------------------------------------------------------------

.request-col-id
  min-width: 40px
  max-width: 40px
  text-align: right
  padding-right: 8px

.request-col-method
  min-width: 70px
  max-width: 70px
  font-weight: 700
  text-transform: uppercase

.request-col-url
  flex: 1
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  padding: 0 8px

.request-col-status
  min-width: 55px
  max-width: 55px
  text-align: center
  font-weight: 700

.request-col-duration
  min-width: 72px
  max-width: 72px
  text-align: right
  padding-right: 8px

.request-col-size
  min-width: 72px
  max-width: 72px
  text-align: right
  padding-right: 4px

// ---------------------------------------------------------------------------
// Status colour classes (used alongside inline colour via `style`)
// ---------------------------------------------------------------------------

.request-status-success
  font-weight: 700

.request-status-redirect
  font-weight: 700

.request-status-client-error
  font-weight: 700

.request-status-server-error
  font-weight: 700

.request-status-unknown
  font-weight: 700
