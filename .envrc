# shellcheck shell=bash
if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
	source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

dotenv_if_exists

git submodule update --init --recursive

# M8 (Incremental-Test-Runner): make io-mon's live read-file capture wiring
# DISCOVERABLE on PATH when the io-mon sibling is present. The runner's
# materialized-recorder read-file capture
# (src/ct_test/incremental/io_mon_capture.nim) resolves the standalone
# `io-mon` CLI via $IO_MON / PATH and the interpose shim via
# $REPRO_MONITOR_SHIM_LIB. When the sibling has been built
# (`nimble buildSnoop && nimble buildShim`), seed those so the live arm runs
# without an install step. Absent / unbuilt ⇒ the runner fails safe to re-run
# (never a fabricated capture), so this is purely opportunistic.
#
# Platform reality (honest): on macOS 26 / arm64e the __DATA,__interpose
# mechanism does not intercept libc calls from modern chained-fixups binaries,
# so a wired capture can still yield an EMPTY read set even for a freshly-built
# user binary. The wiring is correct; the platform capture is the gap.
#   TODO(io-mon live interpose, macOS SIP): system-process / chained-fixups
#   interpose needs a non-DYLD backend (EndpointSecurity) — user binaries are
#   wired here but may capture empty on macOS 26+.
#   TODO(io-mon live interpose, Linux): validate LD_PRELOAD capture on a Linux
#   host (the PATH wiring below is platform-agnostic; only the shim name differs:
#   librepro_monitor_shim.so).
if [[ -d ../io-mon ]]; then
	_io_mon_root="$(cd ../io-mon && pwd)"
	if [[ -x "$_io_mon_root/build/bin/io-mon" ]]; then
		export IO_MON="$_io_mon_root/build/bin/io-mon"
		PATH_add "$_io_mon_root/build/bin"
	fi
	for _shim_ext in dylib so dll; do
		if [[ -f "$_io_mon_root/build/lib/librepro_monitor_shim.$_shim_ext" ]]; then
			export REPRO_MONITOR_SHIM_LIB="$_io_mon_root/build/lib/librepro_monitor_shim.$_shim_ext"
			break
		fi
	done
	export IO_MON_SRC="$_io_mon_root/src"
	if [[ -d ../nim-stackable-hooks ]]; then
		_nim_stackable_hooks_root="$(cd ../nim-stackable-hooks && pwd)"
		export NIM_STACKABLE_HOOKS_SRC="$_nim_stackable_hooks_root/src"
	fi

	# macOS SIP bypass: seed CT_SANDBOX_TOOLS_DIR with a populated drop-in
	# bundle so the io-mon monitor can redirect a SIP-protected exec
	# (/bin/sh, /bin/cat, /usr/bin/grep, …) to an injectable NON-SIP drop-in
	# instead of going blind. On macOS, DYLD_INSERT_LIBRARIES is stripped for
	# SIP binaries and AMFI SIGKILLs a *copy* of a restricted platform binary
	# (even ad-hoc re-signed), so the drop-in must be a binary we build/resolve
	# ourselves — see io-mon's rewriteExecPathForSip and
	# reprobuild-specs/Portable-Macos-Sandbox-Tools.milestones.org.
	#
	# Preference order for the drop-in bundle:
	#   1. The reprobuild-BUILT-FROM-SOURCE bundle
	#      (../reprobuild/recipes/sandbox-tools/bundle) — the distribution-grade
	#      tools (cat/ls/cp/.../bin/sh -> bash) built by
	#      `repro build recipes/sandbox-tools/<tool>` and laid out by
	#      `recipes/sandbox-tools/assemble-bundle.sh`. Every binary links ONLY
	#      /usr/lib/libSystem.B.dylib (no /nix/store, no extra dylibs), so it is
	#      relocatable + AMFI-safe with no install_name_tool step. This is the
	#      M3 deliverable that supersedes the interim nix-symlink bundle.
	#   2. The interim self-contained portable bundle produced by io-mon's
	#      `scripts/build-sandbox-tools.sh` (copies real binaries out of
	#      /nix/store + relocates dylibs).
	# When neither has been built, io-mon's populateReproSandboxTools falls back
	# at run time to dev-shell PATH symlinks in a per-run dir. Either way the
	# io-mon spawn hooks pick the dir up via repro_macos_get_sandbox_tools_dir.
	#
	# Idempotent + non-fatal: only set on macOS, only when not already set, and
	# only when a populated bundle exists. A no-op on Linux/Windows.
	if [[ -z ${CT_SANDBOX_TOOLS_DIR:-} && "$(uname -s)" == "Darwin" ]]; then
		_repro_sbx="../reprobuild/recipes/sandbox-tools/bundle"
		if [[ -x "$_repro_sbx/bin/sh" ]]; then
			_repro_sbx_abs="$(cd "$_repro_sbx" && pwd)"
			export CT_SANDBOX_TOOLS_DIR="$_repro_sbx_abs"
		elif [[ -x "$_io_mon_root/build/sandbox-tools/bin/sh" ]]; then
			export CT_SANDBOX_TOOLS_DIR="$_io_mon_root/build/sandbox-tools"
		fi
		unset _repro_sbx _repro_sbx_abs
	fi

	unset _io_mon_root _nim_stackable_hooks_root _shim_ext
fi

# watch_file "$(find ./nix -name "*.nix" -type f)"

if [[ ${NO_NIX:-} == "1" ]]; then
	# shellcheck source=/dev/null
	source non-nix-build/env.sh
else
	# flake-overrides plugin: prefer a sibling checkout (workspace dev — always
	# current), else the pinned published copy (CI / standalone clones).
	if [[ -f ../direnv-nix-flake-overrides/plugin/flake-overrides.bash ]]; then
		watch_file ../direnv-nix-flake-overrides/plugin/flake-overrides.bash
		# shellcheck source=/dev/null
		source ../direnv-nix-flake-overrides/plugin/flake-overrides.bash
	else
		source_url "https://direnv-flake-overrides.blocksense.network/plugin" \
			"sha256-bqkWqI8UKTvRy8L26qLnT9Is6moil8SIx34ZZoPeR4E="
	fi
	watch_file .env

	# Full-auto: override every flake input that has a same-named sibling
	# checkout next to this repo (honouring the metacraft `-src` suffix
	# convention). The curated list below covers the one input whose name does
	# not match its sibling directory (the wasm recorder is the `wazero` input).
	export NIX_FLAKE_OVERRIDE_AUTO=1
	export NIX_FLAKE_OVERRIDE_AUTO_STRIP_SUFFIXES=-src
	export NIX_FLAKE_OVERRIDE_SIBLINGS='wazero=codetracer-wasm-recorder'
	# Quote the flake ref: ``eval`` re-globs its argument string, and the ``?``
	# in ``.?submodules=1`` is a wildcard. Under ``nullglob`` (active in the
	# direnv load context) it matches no file and VANISHES, shifting the first
	# ``--override-input`` flag into ``$1`` — nix-direnv's ``use_flake`` then
	# rejects it with "the first argument must be a flake expression". Single
	# quotes keep the ref literal through ``eval``. (The ``.``-only repos were
	# unaffected because ``.`` has no glob metacharacter.)
	eval "use flake '.?submodules=1' $(flake_override_args_quoted)"
fi
