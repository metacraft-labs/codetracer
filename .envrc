# shellcheck shell=bash
if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
	source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

dotenv_if_exists

if [[ ${CODETRACER_SKIP_SUBMODULE_UPDATE:-} != "1" ]]; then
	if ! git submodule update --init --recursive; then
		echo "direnv: warning: git submodule update failed; continuing with the existing checkout." >&2
		echo "direnv: warning: export CODETRACER_SKIP_SUBMODULE_UPDATE=1 to skip the automatic update step." >&2
	fi
fi

# watch_file "$(find ./nix -name "*.nix" -type f)"

OS_AND_SYSTEM=$(uname -a)

if [[ ${NO_NIX:-} == "1" || $OS_AND_SYSTEM == "Darwin"* ]]; then
	# shellcheck source=/dev/null
	source non-nix-build/env.sh
else
	# Auto-detect sibling repos and generate --override-input flags
	_ct_override_flags=""
	_ct_flake_target=".?submodules=1"
	# Opt into the heavier Move recorder toolchain only when explicitly requested.
	if [[ ${CODETRACER_ENABLE_SUI:-} == "1" ]]; then
		_ct_flake_target+="#with-sui"
	fi
	declare -A _ct_sibling_map=(
		["codetracer-python-recorder"]="codetracer-python-recorder"
		["codetracer-ruby-recorder"]="codetracer-ruby-recorder"
		["codetracer-js-recorder"]="codetracer-js-recorder"
		["codetracer-shell-recorders"]="codetracer-shell-recorders"
		["codetracer-wasm-recorder"]="wazero"
		["codetracer-trace-format"]="codetracer-trace-format"
		["nix-blockchain-development"]="nix-blockchain-development"
	)
	for _dir in "${!_ct_sibling_map[@]}"; do
		if [[ -d "../$_dir" ]]; then
			_ct_override_flags+=" --override-input ${_ct_sibling_map[$_dir]} path:../$_dir"
		fi
	done
	use flake "${_ct_flake_target}${_ct_override_flags}"
	unset _ct_flake_target _ct_override_flags _ct_sibling_map _dir
fi
